@page "/about"

<PageTitle>UniCore — About</PageTitle>

<div class="about-page">

    <!-- Header -->
    <div class="docs-page-header">
        <span class="docs-badge">About</span>
        <h1 class="docs-title">CBU Junior Design Project</h1>
        <p class="docs-subtitle">
            UniCore was built as a junior design project at California Baptist University
            by a team of five computer science students.
        </p>
    </div>

    <!-- Project description -->
    <section class="about-section">
        <p>
            UniCore is a peer-to-peer distributed computing marketplace. Providers rent out
            spare hardware; consumers get browser-based Linux VMs on demand — no cloud account,
            no port forwarding, no exposed IPs. The whole system runs on a GCP-backed FRP relay
            with Google Firestore as the coordination layer.
        </p>
        <p>
            The project was built across four sprints covering authentication, VM provisioning,
            live migration, volume backups, and public service exposure — using .NET 10, Blazor
            Server, Docker, Firebase, and Google Cloud Platform.
        </p>
    </section>

    <!-- Team -->
    <section class="about-section">
        <h2 class="about-section-title">The Team</h2>
