@namespace unicoreconsumer.Components
@using UniCore.Shared.Models
@inject IConsumerVmService VmService

<div class="stopped-table">
    <div class="table-header">
        <span>VM NAME</span>
        <span>OS / TYPE</span>
        <span>IP ADDRESS</span>
        <span>TOTAL COST</span>
        <span>STATUS</span>
        <span>ACTIONS</span>
    </div>
    @foreach (var vm in Vms)
    {
        <div class="table-row">
            <span class="vm-name-mono">@vm.Name</span>
            <span>@vm.Os &bull; @vm.Specs</span>
            <span>@vm.IpAddress</span>
            <span class="cost-text">@vm.TotalCost</span>
            <span><span class="stopped-badge">STOPPED</span></span>
            <span>
                <button class="delete-btn" @onclick="@(() => OpenDeleteModal(vm))" title="Delete VM">
                    <i class="bi bi-trash"></i>
                </button>
            </span>
        </div>
    }
</div>

@if (_vmPendingDelete is not null)
{
    <div class="del-backdrop" @onclick="CloseDeleteModal">
        <div class="del-modal" @onclick:stopPropagation="true">
            <div class="del-header">
                <i class="bi bi-exclamation-triangle del-icon"></i>
                <span class="del-title">Delete VM</span>
            </div>
            <p class="del-body">
                Delete VM <span class="del-vm-name">'@_vmPendingDelete.Name'</span>? This action permanently erases all
                files, GCS backups, and snapshots. <strong>This cannot be undone.</strong>
            </p>
            <div class="del-actions">
                <button class="del-btn-cancel" @onclick="CloseDeleteModal" disabled="@_deleting">Cancel</button>
                <button class="del-btn-danger" @onclick="ConfirmDeleteAsync" disabled="@_deleting">
                    <i class="bi bi-trash"></i> Delete VM
                </button>
            </div>
        </div>
    </div>
}

@code {
    public class StoppedVm
    {
        public string VmId { get; set; } = "";
        public string Name { get; set; } = "";
        public string Os { get; set; } = "";
        public string Specs { get; set; } = "";
        public string IpAddress { get; set; } = "";
        public string TotalCost { get; set; } = "";
    }

    [Parameter] public List<StoppedVm> Vms { get; set; } = new();
    [Parameter] public EventCallback<string> OnDelete { get; set; }

    private StoppedVm? _vmPendingDelete;
    private bool _deleting;

    private void OpenDeleteModal(StoppedVm vm)
    {
        _vmPendingDelete = vm;
        _deleting = false;
    }

    private void CloseDeleteModal()
    {
        if (_deleting) return;
        _vmPendingDelete = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_vmPendingDelete is null || _deleting) return;

        _deleting = true;
        try
        {
            if (OnDelete.HasDelegate)
                await OnDelete.InvokeAsync(_vmPendingDelete.VmId);
        }
        finally
        {
            _deleting = false;
            _vmPendingDelete = null;
        }
    }
}

