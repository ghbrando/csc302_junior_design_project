@* TermsModal.razor *@
@* Usage: <UniCoreTermsModal IsVisible="true" OnContinue="HandleContinue" OnClose="HandleClose" /> *@

@if (IsVisible)
{
    <div class="uc-overlay" role="dialog" aria-modal="true" aria-labelledby="uc-title">
        <div class="uc-modal">

            @* ── Header ───────────────────────────────────────── *@
            <div class="uc-header">
                <div class="uc-header-icon">
                    <i class="bi bi-shield-shaded uc-header-shield"></i>
                </div>
                <div class="uc-header-text">
                    <h1 id="uc-title">Welcome to UniCore</h1>
                    <span class="uc-subtitle">Client Account &nbsp;·&nbsp; Decentralized Cloud Infrastructure</span>
                </div>
                <button class="uc-close-btn" @onclick="HandleClose" aria-label="Close">✕</button>
            </div>

            @* ── Scrollable Body ──────────────────────────────── *@
            <div class="uc-body">

                @* Terms of Service *@
                <section class="uc-tos-wrapper">
                    <div class="uc-tos-header">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"
                                  stroke="#5a7a92" stroke-width="1.7" stroke-linejoin="round"/>
                            <path d="M14 2v6h6M8 13h8M8 17h6" stroke="#5a7a92" stroke-width="1.7" stroke-linecap="round"/>
                        </svg>
                        <span class="uc-tos-header-label">Terms of Service Agreement</span>
                        <div class="uc-tos-dot"></div>
                    </div>

                    <div class="uc-tos-scroll">
                        <div class="uc-tos-clause"><strong>1. Service Description:</strong> UniCore provides a decentralized compute marketplace where users can offer or consume computational resources.</div>
                        <div class="uc-tos-clause"><strong>2. Provider Obligations:</strong> Providers must maintain reasonable uptime, provide accurate hardware specifications, and allow VMs to run within scheduled periods.</div>
                        <div class="uc-tos-clause"><strong>3. Client Obligations:</strong> Clients must submit legitimate workloads, respect provider resource limits, and pay for consumed resources promptly.</div>
                        <div class="uc-tos-clause"><strong>4. Security &amp; Privacy:</strong> All VMs are sandboxed. UniCore does not access your personal data. Providers are responsible for their own system security.</div>
                        <div class="uc-tos-clause"><strong>5. Payment Terms:</strong> Payments are processed through verified methods. Clients are charged based on actual resource usage. Providers receive payouts after verification.</div>
                        <div class="uc-tos-clause"><strong>6. Liability:</strong> UniCore is not liable for hardware damage, data loss, or service interruptions. Use at your own risk.</div>
                    </div>

                    <div class="uc-agree-row">
                        <input type="checkbox" id="uc-agree" @bind="_hasAgreed" />
                        <label for="uc-agree" class="uc-agree-label">
                            I have read and agree to the Terms of Service, including the automated sandboxing and compute control authorization policies.
                        </label>
                    </div>
                </section>

            </div>@* /.uc-body *@

            @* ── Footer ───────────────────────────────────────── *@
            <div class="uc-footer">
                @if (!_hasAgreed)
                {
                    <span class="uc-footer-hint">Please agree to the terms to continue</span>
                }
                else
                {
                    <span class="uc-footer-hint" style="opacity:0;"><!-- spacer --></span>
                }
                <button class="uc-btn-continue @(_hasAgreed ? "uc-btn-continue--active" : "uc-btn-continue--locked")"
                        disabled="@(!_hasAgreed)"
                        @onclick="HandleContinue">
                    Continue →
                </button>
            </div>

        </div>
    </div>
}

@* ═══════════════════════════════════════════════════════════
   Code-behind
   ═══════════════════════════════════════════════════════════ *@
@code {
    /// <summary>Controls modal visibility.</summary>
    [Parameter] public bool IsVisible { get; set; } = true;

    /// <summary>Raised when the user clicks Continue after agreeing.</summary>
    [Parameter] public EventCallback OnContinue { get; set; }

    /// <summary>Raised when the user closes the modal without agreeing.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _hasAgreed = false;

    private async Task HandleContinue()
    {
        if (_hasAgreed)
            await OnContinue.InvokeAsync();
    }

    private async Task HandleClose()
    {
        _hasAgreed = false;
        await OnClose.InvokeAsync();
    }
}

@* ═══════════════════════════════════════════════════════════
   Scoped styles  (requires <Isolated CSS> or paste into
   app.css / unicore.css and remove the <style> wrapper)
   ═══════════════════════════════════════════════════════════ *@
<style>
    /* ── Variables ──────────────────────────────────────── */
    .uc-overlay {
        --bg-panel:      #0d1117;
        --bg-card:       #111820;
        --bg-card-alt:   #0f1922;
        --bg-tos:        #0a0f14;
        --border-dim:    #1e2d3d;
        --border-glow:   #1e3a4f;
        --accent-green:  #00e5a0;
        --accent-blue:   #3fa8e0;
        --accent-purple: #8b6fff;
        --accent-amber:  #f5a623;
        --text-primary:  #d6e4f0;
        --text-muted:    #5a7a92;
        --text-label:    #8aacbf;
        --text-mono:     #a8c4d4;
        --danger:        #ff4d6d;
        --glow-green:    0 0 12px rgba(0,229,160,.25);
        --glow-blue:     0 0 12px rgba(63,168,224,.22);
        --glow-purple:   0 0 12px rgba(139,111,255,.22);
        --radius:        6px;
        --font-mono:     'JetBrains Mono', 'Cascadia Code', 'Consolas', monospace;
        --font-display:  'Syne', 'Segoe UI', sans-serif;
    }

    /* ── Overlay ────────────────────────────────────────── */
    .uc-overlay {
        position: fixed; inset: 0; z-index: 9999;
        display: flex; align-items: center; justify-content: center;
        background: rgba(4,8,12,.88);
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        font-family: var(--font-mono);
    }

    /* ── Modal shell ────────────────────────────────────── */
    .uc-modal {
        width: 780px; max-width: 96vw; max-height: 92vh;
        background: var(--bg-panel);
        border: 1px solid var(--border-dim);
        border-radius: 10px;
        display: flex; flex-direction: column;
        overflow: hidden;
        box-shadow:
            0 0 0 1px rgba(0,229,160,.06),
            0 32px 80px rgba(0,0,0,.7),
            0 0 60px rgba(0,229,160,.04);
        animation: ucModalIn .35s cubic-bezier(.16,1,.3,1) both;
    }

    @@keyframes ucModalIn {
        from { opacity: 0; transform: scale(.94) translateY(18px); }
        to   { opacity: 1; transform: scale(1)   translateY(0); }
    }

    /* ── Header ─────────────────────────────────────────── */
    .uc-header {
        display: flex; align-items: center; gap: 14px;
        padding: 22px 28px 20px;
        border-bottom: 1px solid var(--border-dim);
        background: linear-gradient(180deg, rgba(0,229,160,.04) 0%, transparent 100%);
        flex-shrink: 0;
    }

    .uc-header-icon {
        width: 42px; height: 42px; flex-shrink: 0;
        background: linear-gradient(135deg,#0b1f33,#091827);
        border: 1px solid rgba(63,168,224,.3);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: var(--glow-blue), inset 0 1px 0 rgba(63,168,224,.15);
    }
    .uc-header-shield {
        font-size: 1.2rem;
        color: #3fa8e0;
    }

    .uc-header-text { flex: 1; }
    .uc-header-text h1 {
        font-family: var(--font-display);
        font-size: 1.35rem; font-weight: 700;
        color: var(--text-primary);
        letter-spacing: .01em; line-height: 1.2;
        margin: 0;
    }
    .uc-subtitle {
        display: block;
        font-size: .72rem; color: var(--text-muted);
        letter-spacing: .12em; text-transform: uppercase;
        margin-top: 3px;
    }

    .uc-close-btn {
        margin-left: auto;
        width: 32px; height: 32px;
        border: 1px solid var(--border-dim); border-radius: 5px;
        background: transparent; color: var(--text-muted);
        cursor: pointer; font-size: 1rem;
        display: flex; align-items: center; justify-content: center;
        transition: all .15s;
    }
    .uc-close-btn:hover {
        background: rgba(255,77,109,.1);
        border-color: rgba(255,77,109,.4);
        color: var(--danger);
    }

    /* ── Body ───────────────────────────────────────────── */
    .uc-body {
        overflow-y: auto; flex: 1;
        padding: 28px;
        display: flex; flex-direction: column; gap: 28px;
        scrollbar-width: thin;
        scrollbar-color: #1e3a4f #0d1117;
    }
    .uc-body::-webkit-scrollbar { width: 6px; }
    .uc-body::-webkit-scrollbar-track { background: #0d1117; }
    .uc-body::-webkit-scrollbar-thumb { background: #1e3a4f; border-radius: 3px; }

    /* ── Section labels ─────────────────────────────────── */
    .uc-section-label {
        display: flex; align-items: center; gap: 10px;
        font-size: .7rem; font-weight: 600;
        letter-spacing: .18em; text-transform: uppercase;
        color: var(--text-label);
        margin-bottom: 14px;
    }
    .uc-section-label--amber { color: var(--accent-amber); }

    /* ── Feature cards ──────────────────────────────────── */
    .uc-feature-cards { display: flex; flex-direction: column; gap: 10px; }

    .uc-card {
        background: var(--bg-card);
        border: 1px solid var(--border-dim);
        border-radius: var(--radius);
        padding: 16px 18px;
        display: flex; align-items: flex-start; gap: 14px;
        position: relative; overflow: hidden;
        transition: border-color .2s, box-shadow .2s;
    }
    .uc-card::before {
        content: ''; position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 2px; border-radius: 2px 0 0 2px;
    }
    .uc-card:hover { border-color: var(--border-glow); }

    .uc-card--green::before { background: var(--accent-green); box-shadow: 0 0 8px rgba(0,229,160,.5); }
    .uc-card--green:hover    { box-shadow: var(--glow-green); }
    .uc-card--blue::before   { background: var(--accent-blue);  box-shadow: 0 0 8px rgba(63,168,224,.5); }
    .uc-card--blue:hover     { box-shadow: var(--glow-blue); }
    .uc-card--purple::before { background: var(--accent-purple); box-shadow: 0 0 8px rgba(139,111,255,.5); }
    .uc-card--purple:hover   { box-shadow: var(--glow-purple); }

    .uc-card-icon {
        width: 32px; height: 32px; flex-shrink: 0; margin-top: 1px;
        border-radius: 6px;
        display: flex; align-items: center; justify-content: center;
    }
    .uc-card--green .uc-card-icon  { background: rgba(0,229,160,.08); }
    .uc-card--blue  .uc-card-icon  { background: rgba(63,168,224,.08); }
    .uc-card--purple .uc-card-icon { background: rgba(139,111,255,.08); }

    .uc-card-content h3 {
        font-size: .82rem; font-weight: 600;
        margin: 0 0 5px; letter-spacing: .02em;
    }
    .uc-card--green  h3 { color: var(--accent-green); }
    .uc-card--blue   h3 { color: var(--accent-blue); }
    .uc-card--purple h3 { color: var(--accent-purple); }

    .uc-card-content p {
        font-size: .76rem; color: var(--text-mono);
        line-height: 1.65; font-weight: 300; margin: 0;
    }

    /* ── Guidelines ─────────────────────────────────────── */
    .uc-guidelines {
        background: var(--bg-card-alt);
        border: 1px solid rgba(245,166,35,.2);
        border-radius: var(--radius);
        padding: 18px 20px;
        box-shadow: 0 0 24px rgba(245,166,35,.04);
    }
    .uc-guidelines-list {
        list-style: none; padding: 0; margin: 0;
        display: flex; flex-direction: column; gap: 12px;
    }
    .uc-guidelines-list li {
        display: flex; align-items: flex-start; gap: 10px;
        font-size: .76rem; color: var(--text-mono);
        line-height: 1.65; font-weight: 300;
    }
    .uc-gl-dot {
        width: 5px; height: 5px; flex-shrink: 0; margin-top: 7px;
        background: var(--accent-amber); border-radius: 50%;
        box-shadow: 0 0 6px rgba(245,166,35,.6);
    }
    .uc-guidelines-list strong { color: var(--text-primary); font-weight: 600; }

    /* ── Terms of Service ───────────────────────────────── */
    .uc-tos-wrapper {
        background: var(--bg-tos);
        border: 1px solid var(--border-dim);
        border-radius: var(--radius);
        overflow: hidden;
    }

    .uc-tos-header {
        padding: 13px 18px;
        border-bottom: 1px solid var(--border-dim);
        background: rgba(255,255,255,.02);
        display: flex; align-items: center; gap: 8px;
    }
    .uc-tos-header-label {
        font-size: .65rem; letter-spacing: .2em;
        text-transform: uppercase; color: var(--text-muted); font-weight: 600;
    }
    .uc-tos-dot {
        width: 5px; height: 5px; border-radius: 50%;
        background: var(--accent-blue); margin-left: auto;
        box-shadow: 0 0 6px rgba(63,168,224,.8);
    }

    .uc-tos-scroll {
        max-height: 190px; overflow-y: auto;
        padding: 18px 18px 4px;
        display: flex; flex-direction: column; gap: 0;
        scrollbar-width: thin;
        scrollbar-color: #1e3a4f #0a0f14;
    }
    .uc-tos-scroll::-webkit-scrollbar { width: 6px; }
    .uc-tos-scroll::-webkit-scrollbar-track { background: #0a0f14; }
    .uc-tos-scroll::-webkit-scrollbar-thumb { background: #1e3a4f; border-radius: 3px; }

    .uc-tos-clause {
        font-size: .74rem; color: var(--text-mono);
        line-height: 1.7; font-weight: 300;
        padding: 0 0 14px;
        border-bottom: 1px solid rgba(255,255,255,.04);
        margin-bottom: 14px;
    }
    .uc-tos-clause:last-child { border-bottom: none; margin-bottom: 0; }
    .uc-tos-clause strong { color: var(--accent-blue); font-weight: 600; }

    /* ── Agree row ──────────────────────────────────────── */
    .uc-agree-row {
        padding: 14px 18px;
        border-top: 1px solid var(--border-dim);
        background: rgba(255,255,255,.015);
        display: flex; align-items: flex-start; gap: 12px;
    }
    .uc-agree-row input[type="checkbox"] {
        width: 16px; height: 16px; flex-shrink: 0; margin-top: 2px;
        accent-color: var(--accent-green); cursor: pointer;
    }
    .uc-agree-label {
        font-size: .74rem; color: var(--text-mono);
        line-height: 1.6; cursor: pointer; user-select: none; font-weight: 300;
    }

    /* ── Footer ─────────────────────────────────────────── */
    .uc-footer {
        padding: 18px 28px; flex-shrink: 0;
        border-top: 1px solid var(--border-dim);
        background: rgba(0,0,0,.25);
        display: flex; align-items: center;
        justify-content: space-between; gap: 12px;
    }
    .uc-footer-hint {
        font-size: .68rem; color: var(--text-muted);
        letter-spacing: .1em; text-transform: uppercase;
    }

    .uc-btn-continue {
        padding: 10px 28px; border-radius: 5px;
        font-family: var(--font-mono);
        font-size: .74rem; font-weight: 600;
        letter-spacing: .14em; text-transform: uppercase;
        cursor: pointer; border: 1px solid;
        transition: all .2s;
    }
    .uc-btn-continue--locked {
        background: transparent;
        border-color: var(--border-dim);
        color: var(--text-muted); cursor: not-allowed;
    }
    .uc-btn-continue--active {
        background: linear-gradient(135deg,#00c97e,#00e5a0);
        border-color: var(--accent-green);
        color: #051a10;
        box-shadow: var(--glow-green), 0 4px 20px rgba(0,229,160,.25);
    }
    .uc-btn-continue--active:hover {
        box-shadow: 0 0 20px rgba(0,229,160,.5), 0 6px 28px rgba(0,229,160,.35);
        transform: translateY(-1px);
    }
</style>
