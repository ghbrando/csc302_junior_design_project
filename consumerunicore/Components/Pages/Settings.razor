@page "/settings"
@using unicoreconsumer.Services
@using unicoreconsumer.Components
@implements IDisposable
@inject IConsumerService ConsumerService
@inject IFirebaseAuthService FirebaseAuthService
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inherits unicoreconsumer.Services.AuthorizedPageBase
@using unicoreconsumer.Services
@using unicore.shared.Models
@using Google.Cloud.Firestore
@inject IPaymentMethodService PaymentMethodService

<div class="settings-page">

    <SettingsHeader Title="Settings" Subtitle="Manage account and preferences" />

    <!-- Profile Information -->
    <SettingsSection Title="PROFILE INFORMATION"     Subtitle="Update your personal details"         Icon="bi-person"
                     IconColor="var(--uc-blue)"         IconBg="rgba(59,130,246,0.15)">
        <ProfileInformation @bind-FullName="fullName" @bind-Email="email" />
    </SettingsSection>

    <!-- Appearance -->
            <SettingsSection Title="APPEARANCE" Subtitle="Display and theme preferences" Icon="bi-palette"
                            IconColor="var(--uc-magenta)" IconBg="rgba(213,0,249,0.15)">
                <ToggleRow Label="Light Mode" Description="Switch between dark and light interface" @bind-IsOn="IsLightMode" />
            </SettingsSection>

    <!-- Notifications -->
    <SettingsSection Title="NOTIFICATIONS"             Subtitle="Configure alert preferences"                 Icon="bi-bell"
                     IconColor="var(--uc-purple)"                 IconBg="rgba(168,85,247,0.15)">
        <ToggleRow Label="Vm Started" Description="Notify when vm started" IsOn="@notifyVmStarted"
                   IsOnChanged="HandleVmStartedChangedAsync" />
        <ToggleRow Label="Vm Completed" Description="Notify when vm completed" IsOn="@notifyVmCompleted"
                   IsOnChanged="HandleVmCompletedChangedAsync" />
    </SettingsSection>

    <!-- Security -->
    <SettingsSection Title="SECURITY"        Subtitle="Manage authentication &amp; access"            Icon="bi-shield"
                     IconColor="var(--uc-teal)"            IconBg="rgba(16,185,129,0.15)">
        <SecurityLinkRow Label="Change Password" Icon="bi-key" OnClick="HandlePasswordResetAsync" />
    </SettingsSection>

    <!-- Payment Methods -->
    <SettingsSection Title="PAYMENT METHODS"    Subtitle="Manage payout destinations"        Icon="bi-credit-card"
                     IconColor="var(--uc-amber)"        IconBg="rgba(255,171,0,0.15)">
        <PaymentMethods
                    Methods="@paymentMethods"
                    OnAdd="HandleAddPaymentMethodAsync"
                    OnSetPrimary="HandleSetPrimaryAsync"
                    OnDelete="HandleDeletePaymentMethodAsync" />
    </SettingsSection>

    <!-- Regional Settings -->
    <SettingsSection Title="REGIONAL SETTINGS"             Subtitle="Timezone and currency"                 Icon="bi-globe"
                     IconColor="var(--uc-sky)"                     IconBg="rgba(0,229,255,0.12)">
        <RegionalSettings @bind-TimeZone="timeZone" @bind-Currency="currency" />
    </SettingsSection>

    <div class="settings-action-bar">
        <div class="settings-action-bar-inner">
            <button class="btn-save" @onclick="HandleSaveAsync" disabled="@(_saving || _loading)">
                @(_saving ? "SAVING..." : "SAVE CHANGES")
            </button>
        </div>
    </div>

    @if (_showStatusToast && !string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="status-toast @(_statusIsError ? "status-error" : "status-success")">@_statusMessage</div>
    }

</div>

@code {
    // Profile
    private string fullName = "";
    private string email = "";

    // Notifications
    private bool notifyVmStarted = true;
    private bool notifyVmCompleted = true;
    private bool notifyBudgetAlert = true;
    private bool notifyPayoutReady = false;
    private bool notifySystemUpdates = false;

    // Regional
    private string timeZone = "UTC-08:00";
    private string currency = "USD";

    // Theme
    private bool _isLightMode = false;
    private bool IsLightMode
    {
        get => _isLightMode;
        set
        {
            _isLightMode = value;
            _ = InvokeAsync(async () =>
            {
                try
                {
                    await JS.InvokeVoidAsync("themeManager.apply", value ? "light" : "dark");
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Theme toggle failed: {ex.Message}");
                }
            });
        }
    }

    // Payment methods
    private List<PaymentMethod> paymentMethods = new();

    private async Task HandleAddPaymentMethodAsync(PaymentMethod method)
    {
        await PaymentMethodService.AddAsync(AuthState.FirebaseUid, method);
        paymentMethods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        StateHasChanged();
    }

    private async Task HandleSetPrimaryAsync(string methodId)
    {
        await PaymentMethodService.SetPrimaryAsync(AuthState.FirebaseUid, methodId);
        paymentMethods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        StateHasChanged();
    }

    private async Task HandleDeletePaymentMethodAsync(string methodId)
    {
        await PaymentMethodService.DeleteAsync(AuthState.FirebaseUid, methodId);
        paymentMethods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        StateHasChanged();
    }

    private bool _loading;
    private bool _saving;
    private string _statusMessage = "";
    private bool _statusIsError;
    private bool _profileLoaded;
    private bool _showStatusToast;
    private CancellationTokenSource? _statusCts;

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthStateChanged;
    }

    private void OnAuthStateChanged()
    {
        if (!string.IsNullOrWhiteSpace(AuthState.FirebaseUid) && !_profileLoaded)
            _ = InvokeAsync(LoadProfileAsync);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            // Load theme first, independently of auth
            try
            {
                var theme = await JS.InvokeAsync<string>("themeManager.current");
                _isLightMode = theme == "light";
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Theme load failed: {ex.Message}");
            }

            // Then load profile if authenticated
            if (!string.IsNullOrWhiteSpace(AuthState.FirebaseUid) && !_profileLoaded)
                await LoadProfileAsync();
        }
    }

    private async Task LoadProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(AuthState.FirebaseUid)) return;

        // Always reload payment methods
        var methods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        paymentMethods = methods;

        if (_profileLoaded) return;

        _loading = true;
        _statusMessage = "";
        StateHasChanged();

        try
        {
            var consumer = await ConsumerService.GetByFirebaseUidAsync(AuthState.FirebaseUid);
            if (consumer != null)
            {
                fullName = consumer.Name;
                email = consumer.Email;
                notifyVmStarted = consumer.NotifyVmStarted;
                notifyVmCompleted = consumer.NotifyVmCompleted;
                notifyBudgetAlert = consumer.NotifyBudgetAlert;
                notifyPayoutReady = consumer.NotifyPayoutReady;
                notifySystemUpdates = consumer.NotifySystemUpdates;
                timeZone = string.IsNullOrWhiteSpace(consumer.TimeZone) ? timeZone : consumer.TimeZone;
                currency = string.IsNullOrWhiteSpace(consumer.Currency) ? currency : consumer.Currency;
            }
            else
            {
                fullName = AuthState.Name ?? "";
                email = AuthState.Email ?? "";
            }

            _profileLoaded = true;
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to load profile: {ex.Message}", true);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task HandleSaveAsync()
    {
        await PersistSettingsAsync(updateAuthState: true, showSuccessMessage: true);
    }

    private async Task HandleVmStartedChangedAsync(bool value)
    {
        notifyVmStarted = value;
        await PersistSettingsAsync(updateAuthState: false, showSuccessMessage: false);
    }

    private async Task HandleVmCompletedChangedAsync(bool value)
    {
        notifyVmCompleted = value;
        await PersistSettingsAsync(updateAuthState: false, showSuccessMessage: false);
    }

    private async Task PersistSettingsAsync(bool updateAuthState, bool showSuccessMessage)
    {
        if (string.IsNullOrWhiteSpace(AuthState.FirebaseUid))
            return;

        if (string.IsNullOrWhiteSpace(fullName))
        {
            if (showSuccessMessage)
                ShowStatus("Full name is required.", true);
            return;
        }

        if (string.IsNullOrWhiteSpace(email))
        {
            if (showSuccessMessage)
                ShowStatus("Email is required.", true);
            return;
        }

        _saving = true;
        if (showSuccessMessage)
            _statusMessage = "";

        try
        {
            var updated = await ConsumerService.UpdateSettingsAsync(
                AuthState.FirebaseUid,
                fullName,
                email,
                notifyVmStarted,
                notifyVmCompleted,
                notifyBudgetAlert,
                notifyPayoutReady,
                notifySystemUpdates,
                timeZone,
                currency);

            fullName = updated.Name;
            email = updated.Email;
            notifyVmStarted = updated.NotifyVmStarted;
            notifyVmCompleted = updated.NotifyVmCompleted;
            notifyBudgetAlert = updated.NotifyBudgetAlert;
            notifyPayoutReady = updated.NotifyPayoutReady;
            notifySystemUpdates = updated.NotifySystemUpdates;
            timeZone = updated.TimeZone;
            currency = updated.Currency;

            if (updateAuthState)
            {
                AuthState.SetAuthState(updated.FirebaseUid, updated.Email, updated.Name);
                await JS.InvokeVoidAsync("authStorage.save", updated.FirebaseUid, updated.Email, updated.Name);
            }

            if (showSuccessMessage)
                ShowStatus("Settings saved.", false);
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to save settings: {ex.Message}", true);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task HandlePasswordResetAsync()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            ShowStatus("Add an email address before requesting a password reset.", true);
            return;
        }

        try
        {
            await FirebaseAuthService.SendPasswordResetEmailAsync(email);
            ShowStatus("Password reset email sent.", false);
        }
        catch (Exception ex)
        {
            ShowStatus($"Password reset failed: {ex.Message}", true);
        }
    }

    private void ShowStatus(string message, bool isError)
    {
        _statusMessage = message;
        _statusIsError = isError;
        _showStatusToast = true;

        _statusCts?.Cancel();
        _statusCts?.Dispose();
        _statusCts = new CancellationTokenSource();
        var token = _statusCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(5000, token);
                await InvokeAsync(() =>
                {
                    _showStatusToast = false;
                    StateHasChanged();
                });
            }
            catch (OperationCanceledException)
            {
            }
        }, token);

        StateHasChanged();
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        _statusCts?.Cancel();
        _statusCts?.Dispose();
    }
}

<style>
    .settings-page {
        padding: 2rem 2.5rem;
        padding-bottom: 6rem;
        max-width: 920px;
        margin: 0 auto;
        font-family: var(--uc-font-base);
    }

    .settings-action-bar {
        position: fixed;
        left: 220px;
        right: 0;
        bottom: 0;
        z-index: 1400;
        padding: 0.9rem 2.5rem 1rem;
        background: linear-gradient(180deg, rgba(2, 6, 23, 0.18) 0%, rgba(2, 6, 23, 0.92) 35%, rgba(2, 6, 23, 0.98) 100%);
        border-top: 1px solid var(--uc-border);
        backdrop-filter: blur(14px);
    }

    body.light-mode .settings-action-bar {
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.7) 0%, rgba(244, 247, 251, 0.94) 40%, rgba(244, 247, 251, 0.98) 100%);
        border-top-color: #cbd5e1;
        box-shadow: 0 -8px 24px rgba(15, 23, 42, 0.08);
    }

    .settings-action-bar-inner {
        max-width: 920px;
        margin: 0 auto;
        display: flex;
        justify-content: flex-end;
    }

    @@media (max-width: 768px) {
        .settings-action-bar {
            left: 0;
            padding: 0.8rem 1rem 0.9rem;
        }
    }

    .btn-save {
        background: var(--uc-teal);
        color: #000;
        border: none;
        padding: 0.7rem 1.6rem;
        border-radius: var(--uc-radius);
        font-size: 0.78rem;
        font-weight: 800;
        letter-spacing: 0.1em;
        cursor: pointer;
        font-family: var(--uc-font-mono);
        transition: background 0.2s;
    }

    body.light-mode .btn-save {
        background: #0f8f4f;
        color: #fff;
    }

    .btn-save:hover {
        background: #0ea572;
    }

    .btn-save:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .status-toast {
        position: fixed;
        left: 50%;
        bottom: 1.25rem;
        transform: translateX(-50%);
        z-index: 1500;
        min-width: 280px;
        max-width: min(90vw, 640px);
        padding: 0.8rem 1rem;
        border-radius: var(--uc-radius);
        font-size: 0.85rem;
        border: 1px solid transparent;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
    }

    .status-success {
        background: rgba(16, 185, 129, 0.12);
        border-color: rgba(16, 185, 129, 0.4);
        color: var(--uc-green);
    }

    .status-error {
        background: rgba(255, 82, 82, 0.12);
        border-color: rgba(255, 82, 82, 0.4);
        color: #ff9a9a;
    }
</style>