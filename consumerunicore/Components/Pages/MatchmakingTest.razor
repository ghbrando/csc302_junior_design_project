@page "/matchmaking-test"
@using consumerunicore.Models
@using consumerunicore.Services
@inject IMatchmakingService MatchmakingService
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<div class="mm-page">
    <h2 class="mm-title">Matchmaking Dev Tool</h2>

    <div class="mm-form">

        <label class="mm-label">
            Region
            <select @bind="region" class="mm-input">
                <option value="US-West">US-West</option>
                <option value="US-East">US-East</option>
                <option value="EU-Central">EU-Central</option>
            </select>
        </label>

        <label class="mm-label">
            CPU Cores Needed
            <input type="number" min="1" @bind="cpuCores"
                   class="mm-input" />
        </label>

        <label class="mm-label">
            RAM (GB) Needed
            <input type="number" min="1" step="0.5" @bind="ramGb"
                   class="mm-input" />
        </label>

        <button @onclick="RunMatchmaking" disabled="@isSearching"
                class="mm-btn">
            @(isSearching ? "Searching..." : "Find Match")
        </button>
    </div>

    @if (isSearching)
    {
        <p class="mm-hint">Querying Firestore...</p>
    }
    else if (searched && result == null)
    {
        <div class="mm-alert mm-alert-error">
            No matching provider found for the given region and resource requirements.
        </div>
    }
    else if (result != null)
    {
        <div class="mm-alert mm-alert-success">
            <div class="mm-success-title">MATCH FOUND</div>

            <table class="mm-table">
                <tr><td class="mm-key">Provider Name</td><td class="mm-value">@result.Provider.Name</td></tr>
                <tr><td class="mm-key">Firebase UID</td><td class="mm-value">@result.Provider.FirebaseUid</td></tr>
                <tr><td class="mm-key">Region</td><td class="mm-value">@result.Provider.Region</td></tr>
                <tr><td class="mm-key">Consistency Score</td><td class="mm-value">@result.ConsistencyScore.ToString("F1")</td></tr>
                <tr><td class="mm-key">Available CPU Cores</td><td class="mm-value">@result.AvailableCpuCores</td></tr>
                <tr><td class="mm-key">Available RAM (GB)</td><td class="mm-value">@result.AvailableRamGb.ToString("F1")</td></tr>
                @if (result.MachineSpecs != null)
                {
                    <tr><td class="mm-key">CPU</td><td class="mm-value">@result.MachineSpecs.CpuName (@result.MachineSpecs.CpuCores cores)</td></tr>
                    <tr><td class="mm-key">Total RAM</td><td class="mm-value">@result.MachineSpecs.RamGB GB</td></tr>
                }
            </table>
        </div>
    }
</div>

<style>
    .mm-page {
        max-width: 560px;
        margin: 40px auto;
        font-family: var(--uc-font-mono);
        color: var(--uc-text-primary);
    }

    .mm-title {
        margin-bottom: 24px;
        color: var(--uc-text-white);
    }

    .mm-form {
        display: flex;
        flex-direction: column;
        gap: 16px;
        background: var(--uc-bg-card);
        padding: 24px;
        border-radius: var(--uc-radius);
        border: 1px solid var(--uc-border);
    }

    .mm-label {
        display: block;
        font-size: 0.82rem;
        color: var(--uc-text-secondary);
    }

    .mm-input {
        display: block;
        width: 100%;
        margin-top: 6px;
        padding: 8px;
        background: var(--uc-bg-elevated);
        color: var(--uc-text-primary);
        border: 1px solid var(--uc-border-light);
        border-radius: 4px;
    }

    .mm-btn {
        padding: 10px 20px;
        background: #7c3aed;
        color: #fff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
    }

    .mm-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .mm-hint {
        margin-top: 20px;
        color: var(--uc-text-muted);
    }

    .mm-alert {
        margin-top: 20px;
        padding: 16px;
        border-radius: var(--uc-radius);
    }

    .mm-alert-error {
        background: rgba(185, 28, 28, 0.15);
        border: 1px solid rgba(185, 28, 28, 0.5);
        color: #fca5a5;
    }

    .mm-alert-success {
        background: rgba(22, 101, 52, 0.15);
        border: 1px solid rgba(22, 101, 52, 0.45);
        padding: 20px;
    }

    .mm-success-title {
        color: #86efac;
        font-size: 13px;
        margin-bottom: 12px;
    }

    .mm-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .mm-key {
        padding: 4px 0;
        color: var(--uc-text-muted);
        width: 180px;
    }

    .mm-value {
        color: var(--uc-text-primary);
    }

    body.light-mode .mm-title {
        color: var(--uc-text-primary);
    }

    body.light-mode .mm-alert-error {
        background: rgba(254, 226, 226, 0.95);
        border-color: rgba(220, 38, 38, 0.35);
        color: #991b1b;
    }

    body.light-mode .mm-alert-success {
        background: rgba(220, 252, 231, 0.95);
        border-color: rgba(22, 163, 74, 0.35);
    }

    body.light-mode .mm-success-title {
        color: #166534;
    }
</style>

@code {
    private string region = "US-West";
    private int cpuCores = 2;
    private double ramGb = 4;
    private bool isSearching = false;
    private MatchmakingResult? result;
    private bool searched = false;

    private async Task RunMatchmaking()
    {
        isSearching = true;
        searched = false;
        result = null;

        result = await MatchmakingService.FindBestMatchAsync(new MatchmakingRequest
        {
            Region = region,
            CpuCoresNeeded = cpuCores,
            RamGbNeeded = ramGb
        });

        searched = true;
        isSearching = false;
    }
}
