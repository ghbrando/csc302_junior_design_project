@namespace unicoreprovider.Components

<style>
    .table-dark-override {
        --bs-table-bg: transparent !important;
        --bs-table-striped-bg: transparent !important;
        --bs-table-hover-bg: var(--uc-bg-elevated) !important;
        --bs-table-color: var(--uc-text-table) !important;
        --bs-table-border-color: var(--uc-border) !important;
        background-color: transparent !important;
        color: var(--uc-text-table) !important;
    }

    .table-dark-override th,
    .table-dark-override td {
        background-color: transparent !important;
        border-bottom: 1px solid var(--uc-border);
    }

    .vm-list-card {
        background-color: var(--uc-bg-card) !important;
        border: 1px solid var(--uc-border) !important;
        border-radius: var(--uc-radius) !important;
    }

    .btn-migrate {
        border: 1px solid rgba(59, 130, 246, 0.4);
        color: var(--uc-blue);
        font-size: 0.7rem;
        font-weight: bold;
        letter-spacing: 0.5px;
        padding: 0.3rem 0.7rem;
        transition: all 0.2s;
        background: transparent;
    }

    .btn-migrate:hover:not(:disabled) {
        background-color: rgba(59, 130, 246, 0.15);
        color: var(--uc-blue);
    }

    .btn-migrate:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .badge-migration-pending {
        background-color: rgba(255, 171, 0, 0.1);
        color: var(--uc-amber);
        border: 1px solid rgba(255, 171, 0, 0.3);
        font-size: 0.65rem;
        padding: 0.3em 0.7em;
        letter-spacing: 0.5px;
    }

    .badge-migration-restoring {
        background-color: rgba(59, 130, 246, 0.1);
        color: var(--uc-blue);
        border: 1px solid rgba(59, 130, 246, 0.3);
        font-size: 0.65rem;
        padding: 0.3em 0.7em;
        letter-spacing: 0.5px;
    }

    .badge-migration-done {
        background-color: rgba(0, 230, 118, 0.1);
        color: var(--uc-green);
        border: 1px solid rgba(0, 230, 118, 0.3);
        font-size: 0.65rem;
        padding: 0.3em 0.7em;
        letter-spacing: 0.5px;
    }

    .badge-migration-failed {
        background-color: rgba(255, 82, 82, 0.1);
        color: var(--uc-red);
        border: 1px solid rgba(255, 82, 82, 0.3);
        font-size: 0.65rem;
        padding: 0.3em 0.7em;
        letter-spacing: 0.5px;
    }
</style>

<div class="card vm-list-card h-100 p-3">
    <div class="d-flex align-items-center mb-3">
        <h6 class="text-uppercase fw-bold mb-0"
            style="letter-spacing: 1px; font-size: 0.75rem; color: var(--uc-text-muted);">
            Active VMs — Docker Sandbox
        </h6>
    </div>

    <div class="table-responsive">
        <table class="table table-dark-override align-middle mb-0">
            <thead>
                <tr class="text-uppercase"
                    style="font-size: 0.7rem; color: var(--uc-text-dim); border-bottom: 1px solid var(--uc-border);">
                    <th class="pb-2 ps-0" style="width: 5%;">VM ID</th>
                    <th class="pb-2" style="width: 12%;">Name</th>
                    <th class="pb-2" style="width: 10%;">Client</th>
                    <th class="pb-2" style="width: 10%;">CPU</th>
                    <th class="pb-2" style="width: 6%;">RAM</th>
                    <th class="pb-2" style="width: 7%;">Duration</th>
                    <th class="pb-2" style="width: 8%;">Vol Sync</th>
                    <th class="pb-2" style="width: 8%;">Last Sync</th>
                    <th class="pb-2" style="width: 8%;">Snapshot</th>
                    <th class="pb-2" style="width: 8%;">Last Snap</th>
                    <th class="pb-2" style="width: 8%;">Migration</th>
                    <th class="pb-2 text-end pe-0" style="width: 16%;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vm in Vms)
                {
                    <tr>
                        <td class="py-3 ps-0"
                            style="font-family: var(--uc-font-mono); color: var(--uc-text-muted); font-size: 0.8rem;">
                            @vm.VmId</td>

                            <td class="py-3 fw-bold" style="color: var(--uc-text-white); font-size: 0.9rem;">
                                @vm.Name@isPaused(vm)</td>

                                <td class="py-3" style="color: var(--uc-text-secondary); font-size: 0.85rem;">@vm.Client</td>

                                <td class="py-3">
                                    @{
                                        var vmCpu = HostCpuCores > 0 && vm.CpuCores > 0
                                            ? Math.Min(100.0, vm.CurrentCpuUsage * HostCpuCores / vm.CpuCores)
                                            : vm.CurrentCpuUsage;
                                    }
                                    <div class="d-flex align-items-center">
                                        <div class="progress me-3"
                                             style="height: 5px; width: 80px; background-color: var(--uc-border); border-radius: 2px;">
                                            <div class="progress-bar"
                                                 style="width: @vmCpu%; background-color: var(--uc-blue); border-radius: 2px;">
                                            </div>
                                        </div>
                                        <span class="small" style="color: var(--uc-text-muted);">@vmCpu.ToString("0")%</span>
                                    </div>
                                </td>

                                <td class="py-3" style="color: var(--uc-text-secondary); font-size: 0.85rem;">@vm.RamGB GB</td>

                                <td class="py-3" style="color: var(--uc-text-secondary); font-size: 0.85rem;">
                                    @(vm.Uptime.Hours)h @(vm.Uptime.Minutes)m
                                </td>

                                <td class="py-3" style="font-size: 0.8rem; color: var(--uc-text-secondary);">@DisplayStatus(vm.VolumeSyncStatus)</td>
                                <td class="py-3" style="font-size: 0.8rem; color: var(--uc-text-secondary);">@DisplayTime(vm.LastVolumeSyncAt)</td>
                                <td class="py-3" style="font-size: 0.8rem; color: var(--uc-text-secondary);">@DisplayStatus(vm.SnapshotStatus)</td>
                                <td class="py-3" style="font-size: 0.8rem; color: var(--uc-text-secondary);">@DisplayTime(vm.LastSnapshotAt)</td>

                                <td class="py-3">
                                    @if (!string.IsNullOrEmpty(vm.MigrationStatus))
                                    {
                                        <span class="badge rounded-pill @MigrationBadgeClass(vm.MigrationStatus)">
                                            @vm.MigrationStatus
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color: var(--uc-text-dim); font-size: 0.75rem;">—</span>
                                    }
                                </td>

                                <td class="py-3 text-end pe-0">
                                    <div class="d-flex justify-content-end gap-2">
                                        <button class="btn btn-sm btn-outline-light rounded-1"
                                                style="font-size: 0.7rem;"
                                                disabled="@(OnSnapshotRequested is null || vm.SnapshotStatus is "Committing" or "Pushing" || _snapshotQueued.Contains(vm.VmId))"
                                                @onclick="() => RequestSnapshotAsync(vm.VmId)">
                                            @if (_snapshotQueued.Contains(vm.VmId))
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                <span>Queued</span>
                                            }
                                            else if (vm.SnapshotStatus is "Committing" or "Pushing")
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                <span>@vm.SnapshotStatus</span>
                                            }
                                            else
                                            {
                                                <span>Snapshot Now</span>
                                            }
                                        </button>
                                        <button class="btn btn-migrate btn-sm rounded-1"
                                                disabled="@(vm.IsPaused || !string.IsNullOrEmpty(vm.MigrationStatus))"
                                                @onclick="() => OnMigrateClicked.InvokeAsync(vm.VmId)">
                                            <i class="bi bi-arrow-left-right me-1"></i>Migrate
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

@code {
    [Parameter] public List<VirtualMachine> Vms { get; set; } = new();
    [Parameter] public int HostCpuCores { get; set; }
    [Parameter] public EventCallback<string> OnMigrateClicked { get; set; }
    [Parameter] public Func<string, Task>? OnSnapshotRequested { get; set; }

    // Tracks VMs where snapshot was just queued, until Firestore confirms it started.
    private readonly HashSet<string> _snapshotQueued = new();

    protected override void OnParametersSet()
    {
        // Once the VM's SnapshotStatus moves away from Idle (to Committing/Pushing),
        // the Firestore listener has picked it up — clear our local "queued" indicator.
        foreach (var vmId in _snapshotQueued.ToList())
        {
            var vm = Vms.FirstOrDefault(v => v.VmId == vmId);
            if (vm == null || vm.SnapshotStatus is "Committing" or "Pushing")
                _snapshotQueued.Remove(vmId);
        }
    }

    private string isPaused(VirtualMachine vm) => vm.IsPaused ? " (Paused)" : "";

    private string MigrationBadgeClass(string? status) => status switch
    {
        "Requested" => "badge-migration-pending",
        "Restoring" => "badge-migration-restoring",
        "Migrated"  => "badge-migration-done",
        "Failed"    => "badge-migration-failed",
        _           => "badge-migration-pending",
    };

    private static string DisplayStatus(string? value) => string.IsNullOrWhiteSpace(value) ? "Idle" : value;

    private static string DisplayTime(DateTime? value) => value.HasValue
        ? value.Value.ToLocalTime().ToString("MM/dd HH:mm")
        : "—";

    private async Task RequestSnapshotAsync(string vmId)
    {
        if (OnSnapshotRequested is null) return;
        _snapshotQueued.Add(vmId);
        try
        {
            await OnSnapshotRequested(vmId);
        }
        catch
        {
            _snapshotQueued.Remove(vmId);
        }
    }
}