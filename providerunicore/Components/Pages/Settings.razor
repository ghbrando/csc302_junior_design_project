@page "/settings"
@using unicoreprovider.Services
@using unicoreprovider.Components
@using Google.Cloud.Firestore
@implements IDisposable
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inherits unicoreprovider.Services.AuthorizedPageBase
@inject IFirebaseAuthService FirebaseAuthService
@inject IMachineService MachineService
@inject IProviderService ProviderService
@inject IPaymentMethodService PaymentMethodService

<PageTitle>Settings</PageTitle>

<div class="container-fluid px-4 py-3">

    <div class="settings-page specs-section">
        <SettingsHeader Title="Settings" Subtitle="Provider configuration & hardware specifications" />

        @* Machine Specs Section *@
        <div class="mb-2">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h6 class="text-uppercase text-muted mb-0"
                    style="font-size: 0.7rem; letter-spacing: 1px; color: var(--uc-text-white);">Machine
                    Specifications</h6>
                    <div class="d-flex align-items-center gap-2">
                        @if (_specs != null)
                        {
                            <span class="text-muted" style="font-size: 0.65rem; color: var(--uc-text-white);">
                                Last detected: @_specs.LastDetected.ToLocalTime().ToString("MMM d, yyyy h:mm tt")
                            </span>
                        }
                        <button class="btn btn-redetect rounded-1" @onclick="ReDetect" disabled="@_detecting">
                            <i class="bi bi-arrow-clockwise me-1"></i>
                            @(_detecting ? "DETECTING..." : (_specs == null ? "DETECT NOW" : "RE-DETECT"))
                        </button>
                    </div>
                </div>

                @if (_specs == null && !_detecting)
                {
                    <div class="specs-empty">
                        <i class="bi bi-cpu specs-empty-icon"></i>
                        <p class="text-muted mb-1" style="font-size: 0.85rem;">No hardware specs detected yet.</p>
                        <p class="text-muted" style="font-size: 0.75rem;">Click "Detect Now" to scan this machine's hardware and
                            save it to your provider profile.</p>
                        </div>
                    }
            else if (_detecting)
                    {
                        <div class="specs-empty">
                            <div class="spinner-border spinner-border-sm text-success mb-2" role="status"></div>
                            <p class="text-muted mb-0" style="font-size: 0.85rem;">Detecting hardware...</p>
                        </div>
                    }
                    else if (_specs != null)
                    {
                        <div class="row g-3">
                            @* CPU *@
                            <div class="col-12 col-md-6 col-lg-4">
                                <div class="spec-card">
                                    <div class="spec-card-header">
                                        <i class="bi bi-cpu spec-icon" style="color: #3b82f6;"></i>
                                        <span class="spec-label">CPU</span>
                                    </div>
                                    <div class="spec-value">@_specs.CpuName</div>
                                    <div class="spec-details">
                                        <span>@_specs.CpuCores cores</span>
                                        <span class="spec-dot">·</span>
                                        <span>@_specs.CpuThreads threads</span>
                                        <span class="spec-dot">·</span>
                                        <span>@_specs.CpuClockSpeedGHz GHz</span>
                                    </div>
                                </div>
                            </div>

                            @* RAM *@
                            <div class="col-12 col-md-6 col-lg-4">
                                <div class="spec-card">
                                    <div class="spec-card-header">
                                        <i class="bi bi-hdd-rack spec-icon" style="color: #a855f7;"></i>
                                        <span class="spec-label">RAM</span>
                                    </div>
                                    <div class="spec-value">@_specs.RamGB GB</div>
                                    <div class="spec-details">
                                        <span>System Memory</span>
                                    </div>
                                </div>
                            </div>

                            @* GPU *@
                            <div class="col-12 col-md-6 col-lg-4">
                                <div class="spec-card">
                                    <div class="spec-card-header">
                                        <i class="bi bi-gpu-card spec-icon" style="color: #10b981;"></i>
                                        <span class="spec-label">GPU</span>
                                    </div>
                                    <div class="spec-value">@(_specs.GpuName == string.Empty ? "Not Detected" : _specs.GpuName)
                                    </div>
                                    <div class="spec-details">
                                        @if (_specs.VramGB > 0)
                                        {
                                            <span>@_specs.VramGB GB VRAM</span>
                                        }
                                        else
                                        {
                                            <span>VRAM not reported</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* Disk *@
                            <div class="col-12 col-md-6 col-lg-4">
                                <div class="spec-card">
                                    <div class="spec-card-header">
                                        <i class="bi bi-device-hdd spec-icon" style="color: #f59e0b;"></i>
                                        <span class="spec-label">Storage</span>
                                    </div>
                                    <div class="spec-value">@_specs.DiskGB GB</div>
                                    <div class="spec-details">
                                        <span>Total Disk Capacity</span>
                                    </div>
                                </div>
                            </div>

                            @* OS *@
                            <div class="col-12 col-md-6 col-lg-4">
                                <div class="spec-card">
                                    <div class="spec-card-header">
                                        <i class="bi bi-window spec-icon" style="color: #00e5ff;"></i>
                                        <span class="spec-label">Operating System</span>
                                    </div>
                                    <div class="spec-value">@_specs.OsName</div>
                                    <div class="spec-details">
                                        <span>Host OS</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div> <!-- end machine specs wrapper -->

        <style>
            .btn-redetect {
                border: 1px solid var(--uc-border);
                color: var(--uc-text-muted);
                font-size: 0.65rem;
                font-weight: bold;
                letter-spacing: 1px;
                padding: 0.35rem 0.75rem;
                background: transparent;
                transition: all 0.2s;
            }

            .btn-redetect:hover:not(:disabled) {
                background-color: rgba(0, 230, 118, 0.08);
                border-color: var(--uc-green);
                color: var(--uc-green);
            }

            .btn-redetect:disabled {
                opacity: 0.5;
                cursor: not-allowed;
            }

            .specs-empty {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 3rem;
                border: 1px dashed var(--uc-border);
                border-radius: var(--uc-radius);
                text-align: center;
            }

            .specs-empty-icon {
                font-size: 2rem;
                color: var(--uc-text-muted);
                margin-bottom: 0.75rem;
            }

            .spec-card {
                background-color: var(--uc-bg-card);
                border: 1px solid var(--uc-border);
                border-radius: var(--uc-radius);
                padding: 1rem 1.25rem;
            }

            .spec-card-header {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                margin-bottom: 0.5rem;
            }

            .spec-icon {
                font-size: 1rem;
            }

            .spec-label {
                font-size: 0.65rem;
                font-weight: 600;
                letter-spacing: 1px;
                color: var(--uc-text-muted);
                text-transform: uppercase;
            }

            .spec-value {
                font-size: 0.95rem;
                font-weight: 600;
                color: var(--uc-text-white);
                margin-bottom: 0.25rem;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .spec-details {
                font-size: 0.7rem;
                color: var(--uc-text-muted);
            }

            .spec-dot {
                margin: 0 0.25rem;
            }
        </style>

        <div class="settings-page">

            <!-- Profile Information -->
            <SettingsSection Title="PROFILE INFORMATION" Subtitle="Update your personal details" Icon="bi-person"
                             IconColor="var(--uc-blue)" IconBg="rgba(59,130,246,0.15)">
                <ProfileInformation @bind-FullName="fullName" @bind-Email="email" />
            </SettingsSection>

            <!-- Appearance -->
            <SettingsSection Title="APPEARANCE" Subtitle="Display and theme preferences" Icon="bi-palette"
                             IconColor="var(--uc-magenta)" IconBg="rgba(213,0,249,0.15)">
                <ToggleRow Label="Light Mode" Description="Switch between dark and light interface" @bind-IsOn="IsLightMode" />
            </SettingsSection>

            <!-- Notifications -->
            <SettingsSection Title="NOTIFICATIONS" Subtitle="Configure alert preferences" Icon="bi-bell"
                             IconColor="var(--uc-purple)" IconBg="rgba(168,85,247,0.15)">
                <ToggleRow Label="Vm Started" Description="Notify when vm started" IsOn="@notifyVmStarted"
                           IsOnChanged="HandleVmStartedChangedAsync" />
                <ToggleRow Label="Vm Completed" Description="Notify when vm completed" IsOn="@notifyVmCompleted"
                           IsOnChanged="HandleVmCompletedChangedAsync" />
            </SettingsSection>

            <!-- Security -->
            <SettingsSection Title="SECURITY" Subtitle="Manage authentication &amp; access" Icon="bi-shield"
                             IconColor="var(--uc-teal)" IconBg="rgba(16,185,129,0.15)">
                <SecurityLinkRow Label="Change Password" Icon="bi-key" OnClick="HandlePasswordResetAsync" />
            </SettingsSection>

            <!-- Payment Methods -->
            <SettingsSection Title="PAYMENT METHODS" Subtitle="Manage payout destinations" Icon="bi-credit-card"
                             IconColor="var(--uc-amber)" IconBg="rgba(255,171,0,0.15)">
                <PaymentMethods
                            Methods="@paymentMethods"
                            OnAdd="HandleAddPaymentMethodAsync"
                            OnSetPrimary="HandleSetPrimaryAsync"
                            OnDelete="HandleDeletePaymentMethodAsync" />
            </SettingsSection>

            <!-- Regional Settings -->
            <SettingsSection Title="REGIONAL SETTINGS" Subtitle="Timezone and currency" Icon="bi-globe"
                             IconColor="var(--uc-sky)" IconBg="rgba(0,229,255,0.12)">
                <RegionalSettings @bind-TimeZone="timeZone" @bind-Currency="currency" />
            </SettingsSection>

        </div>

        <div class="settings-action-bar">
            <div class="settings-action-bar-inner">
                <button class="btn-save" @onclick="HandleSaveAsync" disabled="@(_saving || _loading)">
                    @(_saving ? "SAVING..." : "SAVE CHANGES")
                </button>
            </div>
        </div>

        @if (_showStatusToast && !string.IsNullOrWhiteSpace(_statusMessage))
        {
            <div class="status-toast @(_statusIsError ? "status-error" : "status-success")">@_statusMessage</div>
        }

        <style>
            .settings-page {
                padding: 2rem 2.5rem;
                padding-bottom: 6rem;
                max-width: 920px;
                margin: 0 auto;
                font-family: var(--uc-font-base);
            }

            .settings-action-bar {
                position: fixed;
                left: 220px;
                right: 0;
                bottom: 0;
                z-index: 1400;
                padding: 0.9rem 2.5rem 1rem;
                background: linear-gradient(180deg, rgba(2, 6, 23, 0.18) 0%, rgba(2, 6, 23, 0.92) 35%, rgba(2, 6, 23, 0.98) 100%);
                border-top: 1px solid var(--uc-border);
                backdrop-filter: blur(14px);
            }

            body.light-mode .settings-action-bar {
                background: linear-gradient(180deg, rgba(255, 255, 255, 0.7) 0%, rgba(244, 247, 251, 0.94) 40%, rgba(244, 247, 251, 0.98) 100%);
                border-top-color: #cbd5e1;
                box-shadow: 0 -8px 24px rgba(15, 23, 42, 0.08);
            }

            .settings-action-bar-inner {
                max-width: 920px;
                margin: 0 auto;
                display: flex;
                justify-content: flex-end;
            }

            @@media (max-width: 768px) {
                .settings-action-bar {
                    left: 0;
                    padding: 0.8rem 1rem 0.9rem;
                }
            }

            /* make all text in specs section white */
            .specs-section {
                color: var(--uc-text-white);
            }

            .specs-section .text-muted {
                color: var(--uc-text-white) !important;
            }

            body.light-mode .specs-section .text-muted {
                color: var(--uc-text-secondary) !important;
            }

            .btn-save {
                background: var(--uc-teal);
                color: #000;
                border: none;
                padding: 0.7rem 1.6rem;
                border-radius: var(--uc-radius);
                font-size: 0.78rem;
                font-weight: 800;
                letter-spacing: 0.1em;
                cursor: pointer;
                font-family: var(--uc-font-mono);
                transition: background 0.2s;
            }

            body.light-mode .btn-save {
                background: #0f8f4f;
                color: #fff;
            }

            .btn-save:hover {
                background: #0ea572;
            }

            .btn-save:disabled {
                opacity: 0.6;
                cursor: not-allowed;
            }

            .status-toast {
                position: fixed;
                left: 50%;
                bottom: 1.25rem;
                transform: translateX(-50%);
                z-index: 1500;
                min-width: 280px;
                max-width: min(90vw, 640px);
                padding: 0.8rem 1rem;
                border-radius: var(--uc-radius);
                font-size: 0.85rem;
                border: 1px solid transparent;
                box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
            }

            .status-success {
                background: rgba(16, 185, 129, 0.12);
                border-color: rgba(16, 185, 129, 0.4);
                color: var(--uc-green);
            }

            .status-error {
                background: rgba(255, 82, 82, 0.12);
                border-color: rgba(255, 82, 82, 0.4);
                color: #ff9a9a;
            }
        </style>

@code {
    private MachineSpecs? _specs;
    private bool _detecting = false;
    private FirestoreChangeListener? _specsListener;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnChange += OnAuthStateChanged;

        if (AuthState.FirebaseUid != null)
        {
            _specs = await MachineService.GetCachedSpecsAsync();
            StartListener();
        }
    }

    private void StartListener()
    {
        if (AuthState.FirebaseUid == null) return;

        _specsListener = MachineService.ListenSpecs(AuthState.FirebaseUid, specs =>
        {
            _specs = specs;
            _ = InvokeAsync(StateHasChanged);
        });
    }

    private void OnAuthStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            if (AuthState.FirebaseUid != null)
            {
                _specs = await MachineService.GetCachedSpecsAsync();
                StartListener();
            }

            if (!string.IsNullOrWhiteSpace(AuthState.FirebaseUid) && !_profileLoaded)
            {
                await LoadProfileAsync();
            }
        });

    }

    private async Task ReDetect()
    {
        if (AuthState.FirebaseUid == null) return;
        _detecting = true;
        StateHasChanged();
        try
        {
            _specs = await MachineService.GetSpecsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Hardware detection failed: {ex.Message}");
        }
        finally
        {
            _detecting = false;
        }
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        _ = _specsListener?.StopAsync();
        _statusCts?.Cancel();
        _statusCts?.Dispose();
    }

    // Theme
    private bool _isLightMode = false;
    private bool IsLightMode
    {
        get => _isLightMode;
        set
        {
            _isLightMode = value;
            _ = JS.InvokeVoidAsync("themeManager.apply", value ? "light" : "dark");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JS.InvokeAsync<string>("themeManager.current");
            _isLightMode = theme == "light";
            StateHasChanged();
        }

        if (firstRender && !string.IsNullOrWhiteSpace(AuthState.FirebaseUid) && !_profileLoaded)
            await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        if (string.IsNullOrWhiteSpace(AuthState.FirebaseUid) || _profileLoaded)
            return;

        _loading = true;
        _statusMessage = "";
        StateHasChanged();

        try
        {
            var provider = await ProviderService.GetByFirebaseUidAsync(AuthState.FirebaseUid);
            if (provider != null)
            {
                fullName = provider.Name;
                email = provider.Email;
                notifyVmStarted = provider.NotifyVmStarted;
                notifyVmCompleted = provider.NotifyVmCompleted;
                notifyBudgetAlert = provider.NotifyBudgetAlert;
                notifyPayoutReady = provider.NotifyPayoutReady;
                notifySystemUpdates = provider.NotifySystemUpdates;
                timeZone = string.IsNullOrWhiteSpace(provider.TimeZone) ? timeZone : provider.TimeZone;
                currency = string.IsNullOrWhiteSpace(provider.Currency) ? currency : provider.Currency;
            }
            else
            {
                fullName = AuthState.Name ?? "";
                email = AuthState.Email ?? "";
            }
            _profileLoaded = true;
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to load profile: {ex.Message}", true);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
        var methods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        paymentMethods = methods;
    }


    // Profile
    private string fullName = "";
    private string email = "";

    // Notifications
    private bool notifyVmStarted = true;
    private bool notifyVmCompleted = true;
    private bool notifyBudgetAlert = true;
    private bool notifyPayoutReady = false;
    private bool notifySystemUpdates = false;

    // Regional
    private string timeZone = "UTC-08:00";
    private string currency = "USD";

    // Payment methods
    private List<PaymentMethod> paymentMethods = new();

    // Add these handlers to pass into the PaymentMethods component:
    private async Task HandleAddPaymentMethodAsync(PaymentMethod method)
    {
        await PaymentMethodService.AddAsync(AuthState.FirebaseUid, method);
        paymentMethods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        StateHasChanged();
    }

    private async Task HandleSetPrimaryAsync(string methodId)
    {
        await PaymentMethodService.SetPrimaryAsync(AuthState.FirebaseUid, methodId);
        paymentMethods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        StateHasChanged();
    }

    private async Task HandleDeletePaymentMethodAsync(string methodId)
    {
        await PaymentMethodService.DeleteAsync(AuthState.FirebaseUid, methodId);
        paymentMethods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        StateHasChanged();
    }

    private bool _loading;
    private bool _saving;
    private string _statusMessage = "";
    private bool _statusIsError;
    private bool _profileLoaded;
    private bool _showStatusToast;
    private CancellationTokenSource? _statusCts;


    private async Task HandleSaveAsync()
    {
        await PersistSettingsAsync(updateAuthState: true, showSuccessMessage: true);
    }

    private async Task HandleVmStartedChangedAsync(bool value)
    {
        notifyVmStarted = value;
        await PersistSettingsAsync(updateAuthState: false, showSuccessMessage: false);
    }

    private async Task HandleVmCompletedChangedAsync(bool value)
    {
        notifyVmCompleted = value;
        await PersistSettingsAsync(updateAuthState: false, showSuccessMessage: false);
    }

    private async Task PersistSettingsAsync(bool updateAuthState, bool showSuccessMessage)
    {
        if (string.IsNullOrWhiteSpace(AuthState.FirebaseUid)) return;
        if (string.IsNullOrWhiteSpace(fullName) || string.IsNullOrWhiteSpace(email))
        {
            if (showSuccessMessage)
                ShowStatus("Full name and email cannot be empty.", true);
            return;
        }
        if (string.IsNullOrWhiteSpace(email))
        {
            if (showSuccessMessage)
                ShowStatus("Email cannot be empty.", true);
            return;
        }

        _saving = true;
        if (showSuccessMessage)
            _statusMessage = "";

        try
        {
            var updated = await ProviderService.UpdateSettingsAsync(
                AuthState.FirebaseUid,
                fullName,
                email,
                notifyVmStarted,
                notifyVmCompleted,
                notifyBudgetAlert,
                notifyPayoutReady,
                notifySystemUpdates,
                timeZone,
                currency);

            fullName = updated.Name;
            email = updated.Email;
            notifyVmStarted = updated.NotifyVmStarted;
            notifyVmCompleted = updated.NotifyVmCompleted;
            notifyBudgetAlert = updated.NotifyBudgetAlert;
            notifyPayoutReady = updated.NotifyPayoutReady;
            notifySystemUpdates = updated.NotifySystemUpdates;
            timeZone = updated.TimeZone;
            currency = updated.Currency;

            if (updateAuthState)
            {
                AuthState.SetAuthState(updated.FirebaseUid, updated.Email, updated.Name);
                await JS.InvokeVoidAsync("authStorage.save", updated.FirebaseUid, updated.Email, updated.Name);
            }

            if (showSuccessMessage)
                ShowStatus("Profile updated successfully!", false);
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to update profile: {ex.Message}", true);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task HandlePasswordResetAsync()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            ShowStatus("Email cannot be empty.", true);
            return;
        }
        try
        {
            await FirebaseAuthService.SendPasswordResetEmailAsync(email);
            ShowStatus("Password reset email sent!", false);
        }
        catch (Exception ex)
        {
            ShowStatus($"Failed to send password reset email: {ex.Message}", true);
        }
    }
    
    private void ShowStatus(string message, bool isError)
    {
        _statusMessage = message;
        _statusIsError = isError;
        _showStatusToast = true;

        _statusCts?.Cancel();
        _statusCts?.Dispose();
        _statusCts = new CancellationTokenSource();
        var token = _statusCts.Token;
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(5000, token);
                await InvokeAsync(() =>
                {
                    _showStatusToast = false;
                    StateHasChanged();
                });
            }
            catch (OperationCanceledException) { }
        }, token);
    }

}