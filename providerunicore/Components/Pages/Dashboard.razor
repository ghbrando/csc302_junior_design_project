@page "/dashboard/"
@using unicoreprovider.Services
@using unicoreprovider.Components
@using Microsoft.AspNetCore.Components.Web
@using System.Threading
@using System.Collections.Generic
@using Google.Cloud.Firestore
@implements IDisposable
@inject IVmService VmService
@inject IProviderService ProviderService
@inject IMachineService MachineService
@inject IDockerService DockerService
@inject ContainerMonitorService MonitorService
@inject PauseResumeListenerService PauseResumeListenerService
@inject IConfiguration Configuration
@inject FirestoreDb FirestoreDb
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inherits unicoreprovider.Services.AuthorizedPageBase

<PageTitle>Provider Node</PageTitle>

<style>
    .badge-online {
        background-color: rgba(0, 230, 118, 0.1);
        color: var(--uc-green);
        border: 1px solid rgba(0, 230, 118, 0.3);
        font-size: 0.65rem;
        padding: 0.35em 0.8em;
        letter-spacing: 1px;
    }

    .btn-emergency {
        border: 1px solid var(--uc-red-dark);
        color: var(--uc-red);
        font-size: 0.7rem;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.5rem 1rem;
        transition: all 0.2s;
    }

    .btn-emergency:hover {
        background-color: var(--uc-red-dark);
        color: white;
    }

    .btn-launch-vm {
        border: 1px solid rgba(0, 230, 118, 0.4);
        color: var(--uc-green);
        font-size: 0.7rem;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.5rem 1rem;
        transition: all 0.2s;
    }

    .btn-launch-vm:hover:not(:disabled) {
        background-color: rgba(0, 230, 118, 0.15);
        color: var(--uc-green);
    }

    .btn-launch-vm:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* CSS-driven modal — no JS interop needed */
    .uc-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .uc-modal {
        background: var(--uc-dark-2);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 1.75rem;
        width: 100%;
        max-width: 420px;
    }

    .uc-modal-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: #e2e8f0;
        margin-bottom: 1.25rem;
    }

    .uc-label {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.8px;
        color: #64748b;
        text-transform: uppercase;
        margin-bottom: 0.4rem;
    }

    .uc-select {
        background: #0f172a;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #e2e8f0;
        font-size: 0.83rem;
        border-radius: 4px;
        padding: 0.45rem 0.7rem;
        width: 100%;
    }

    .uc-select:focus {
        outline: none;
        border-color: rgba(0, 230, 118, 0.5);
    }
</style>

<div class="container-fluid px-4 py-3">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="d-flex align-items-center gap-3">
                <h5 class="fw-bold text-white mb-0" style="letter-spacing: 0.5px;">Provider Node</h5>
                <span class="badge rounded-pill badge-online">ONLINE</span>
            </div>
            <p class="text-muted mb-0 mt-1" style="font-size: 0.8rem;">Real-time resource monitoring & control</p>
        </div>

        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-launch-vm rounded-1" @onclick="OpenLaunchModal">
                <i class="bi bi-play-circle me-2"></i> LAUNCH VM
            </button>
            <button class="btn btn-emergency rounded-1" @onclick="OpenStopModal">
                <i class="bi bi-exclamation-octagon-fill me-2"></i> EMERGENCY STOP
            </button>
        </div>
    </div>

    <div class="row mb-3 g-3">
        @{
            var runningCount = Vms.Count(v => v.Status == "Running");
            var totalHourlyRate = Vms.Where(v => v.Status == "Running").Sum(v => v.CostPerHour);
            var longestUptime = Vms
            .Where(v => v.Status == "Running" && v.Uptime > TimeSpan.Zero)
            .OrderByDescending(v => v.Uptime)
            .Select(v => v.UptimeString)
            .FirstOrDefault();
            var uptime = longestUptime ?? "N/A";
        }

        <div class="col-12 col-md-6 col-lg-3">
            <NodeStatusCard NodeStatus="@CurrentNodeStatus" OnNodeStatusChanged="HandleNodeStatusChanged" />
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Active VMs" Value="@runningCount.ToString()" Unit="running" IconClass="bi bi-activity"
                      Color="#3b82f6" />
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Hourly Rate" Value="@totalHourlyRate.ToString("C")" Unit="/hr"
                      IconClass="bi bi-graph-up-arrow" Color="#00e676" ValueColor="#00e676" />
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Longest VM Uptime" Value="@uptime" Unit="" IconClass="bi bi-lightning-charge-fill"
                      Color="#ffeb3b" />
        </div>
    </div>

    <div class="row mb-3 g-3">
        <div class="col-md-6">
            <ResourceSlider Title="CPU CORE LIMIT" Unit="percent" Max="100" MinLimit="20" Color="#00E5FF"
                            IconClass="bi bi-cpu" Value="@CpuLimit" ValueChanged="@(v => OnSliderChanged(ref _cpuLimit, v))" />
        </div>
        <div class="col-md-6">
            <ResourceSlider Title="RAM ALLOCATION" Unit="gigabytes"
                            Max="@(_specs?.RamGB > 0 ? (double)_specs.RamGB : 128)" MinLimit="1" Color="#D500F9"
                            IconClass="bi bi-hdd-rack" Value="@RamLimit" ValueChanged="@(v => OnSliderChanged(ref _ramLimit, v))" />
        </div>
    </div>

    <div class="row mb-3 g-3">
        <div class="col-12">
            <h6 class="text-uppercase text-muted"
                style="font-size: 0.7rem; letter-spacing: 1px; margin-left: 4px; margin-bottom: 8px;">
                Real-Time Monitoring
            </h6>
        </div>
        @{
            var activeVms = Vms.Where(v => v.Status == "Running").ToList();
            var avgCpu = activeVms.Any() ? activeVms.Average(v => v.CurrentCpuUsage) : 0;
            var avgGpu = activeVms.Any() ? activeVms.Average(v => v.CurrentGpuUsage) : 0;
            var avgRam = activeVms.Any() ? activeVms.Average(v => v.CurrentRamUsage) : 0;
            var demoVm = activeVms.FirstOrDefault() ?? new VirtualMachine();
        }
        <div class="col-md-4">
            <MetricCard Title="CPU" Value="@avgCpu.ToString("0")" Percent="@((double)avgCpu)" Color="#3b82f6"
                        DataPoints="@demoVm.CpuHistory" />
        </div>
        <div class="col-md-4">
            <MetricCard Title="GPU" Value="@avgGpu.ToString("0")" Percent="@((double)avgGpu)" Color="#10b981"
                        DataPoints="@demoVm.GpuHistory" />
        </div>
        <div class="col-md-4">
            <MetricCard Title="RAM" Value="@((activeVms.Sum(v => v.RamGB) * (avgRam / 100)).ToString("0.0"))" Unit="GB"
                        Percent="@((double)avgRam)" Color="#a855f7" DataPoints="@demoVm.RamHistory" />
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <VmList Vms="@Vms.Where(v => v.Status == "Running").ToList()" HostCpuCores="@(_specs?.CpuThreads ?? 0)" />
        </div>
    </div>

</div>

<!-- Launch VM modal -->
@if (_showLaunchModal)
{
    <div class="uc-modal-backdrop" @onclick="CloseLaunchModal">
        <div class="uc-modal" @onclick:stopPropagation="true">
            <div class="uc-modal-title">
                <i class="bi bi-play-circle me-2" style="color: var(--uc-green);"></i>
                Launch Virtual Machine
            </div>

            <div class="mb-3">
                <div class="uc-label">Container Image</div>
                <select class="uc-select" @bind="_selectedImage">
                    @foreach (var img in AvailableImages)
                    {
                        <option value="@img.Value">@img.Label</option>
                    }
                </select>
            </div>

            @{
                var availCores = AvailableCpuCores;
                var availRam = AvailableRamGB;
            }

            <div class="mb-2" style="font-size: 0.72rem; color: #64748b; letter-spacing: 0.5px;">
                AVAILABLE BUDGET &nbsp;—&nbsp;
                <span style="color: @(availCores > 0 ? "#00e676" : "var(--uc-red)");">@availCores core@(availCores == 1 ? "" : "s")</span>
                &nbsp;/&nbsp;
                <span style="color: @(availRam > 0 ? "#00e676" : "var(--uc-red)");">@availRam GB RAM</span>
            </div>

            @if (availCores == 0 || availRam == 0)
            {
                <div class="alert py-2 mb-3"
                     style="font-size: 0.78rem; background: rgba(244,67,54,0.1); border: 1px solid rgba(244,67,54,0.3); color: #ef9a9a;">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    No resources available. Raise your CPU or RAM limit, or stop a running VM first.
                </div>
            }

            <div class="row g-2 mb-3">
                <div class="col-6">
                    <div class="uc-label">CPU Cores</div>
                    <select class="uc-select" @bind="_selectedCpuCores" disabled="@(availCores == 0)">
                        @for (int c = 1; c <= availCores; c++)
                        {
                            var val = c;
                            <option value="@val">@val core@(val == 1 ? "" : "s")</option>
                        }
                        @if (availCores == 0)
                        {
                            <option value="0">— none available —</option>
                        }
                    </select>
                </div>
                <div class="col-6">
                    <div class="uc-label">RAM</div>
                    <select class="uc-select" @bind="_selectedRamGB" disabled="@(availRam == 0)">
                        @for (int r = 1; r <= availRam; r++)
                        {
                            var val = r;
                            <option value="@val">@val GB</option>
                        }
                        @if (availRam == 0)
                        {
                            <option value="0">— none available —</option>
                        }
                    </select>
                </div>
            </div>

            @if (_launchError != null)
            {
                <div class="alert alert-danger py-2 mb-3" style="font-size: 0.78rem;">
                    <i class="bi bi-exclamation-circle me-1"></i>@_launchError
                </div>
            }

            <div class="d-flex justify-content-end gap-2 mt-3">
                <button class="btn btn-sm btn-outline-secondary rounded-1" @onclick="CloseLaunchModal"
                        disabled="@_isLaunching">
                    Cancel
                </button>
                <button class="btn btn-sm btn-launch-vm rounded-1" @onclick="LaunchVmAsync"
                        disabled="@(_isLaunching || AvailableCpuCores == 0 || AvailableRamGB == 0)">
                    @if (_isLaunching)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Launching...</span>
                    }
                    else
                    {
                        <i class="bi bi-play-circle me-1"></i>
                        <span>Launch</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- Emergency Stop modal -->
@if (_showStopModal)
{
    <div class="uc-modal-backdrop" @onclick="CloseStopModal">
        <div class="uc-modal" style="max-width: 520px;" @onclick:stopPropagation="true">
            <div class="uc-modal-title">
                <i class="bi bi-exclamation-octagon-fill me-2" style="color: var(--uc-red);"></i>
                Emergency Stop
            </div>

            @{
                var runningVms = Vms.Where(v => v.Status == "Running").ToList();
            }

            @if (!runningVms.Any())
            {
                <p class="text-muted" style="font-size: 0.82rem;">No running VMs to stop.</p>
            }
            else
            {
                <p class="text-muted mb-2" style="font-size: 0.78rem;">Select which VMs to stop:</p>

                <div class="mb-2 d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary rounded-1" style="font-size: 0.7rem;"
                            @onclick="SelectAllVms">
                        All
                    </button>
                    <button class="btn btn-sm btn-outline-secondary rounded-1" style="font-size: 0.7rem;"
                            @onclick="DeselectAllVms">
                        None
                    </button>
                </div>

                <div class="mb-3" style="max-height: 200px; overflow-y: auto;">
                    @foreach (var vm in runningVms)
                    {
                        <div class="d-flex align-items-center gap-2 py-1 px-2 mb-1 rounded-1"
                             style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
                            <input type="checkbox" class="form-check-input mt-0" checked="@_selectedVmIds.Contains(vm.VmId)"
                                   @onchange="@(e => ToggleVmSelection(vm.VmId, (bool)(e.Value ?? false)))" />
                            <div>
                                <div style="font-size: 0.8rem; color: #e2e8f0;">@vm.Name</div>
                                <div style="font-size: 0.7rem; color: #64748b;">@vm.Image &nbsp;·&nbsp; @vm.UptimeString</div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (_stopError != null)
            {
                <div class="alert alert-danger py-2 mb-3" style="font-size: 0.78rem;">
                    <i class="bi bi-exclamation-circle me-1"></i>@_stopError
                </div>
            }

            <div class="d-flex justify-content-end gap-2 mt-3">
                <button class="btn btn-sm btn-outline-secondary rounded-1" @onclick="CloseStopModal"
                        disabled="@_isStopping">
                    Cancel
                </button>
                <button class="btn btn-sm btn-emergency rounded-1" @onclick="StopSelectedVmsAsync"
                        disabled="@(_isStopping || !_selectedVmIds.Any())">
                    @if (_isStopping)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Stopping...</span>
                    }
                    else
                    {
                        <i class="bi bi-stop-circle me-1"></i>
                        <span>Stop Selected (@_selectedVmIds.Count)</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── Available images ──────────────────────────────────────────────────────

    private record ImageOption(string Label, string Value);

    private static readonly ImageOption[] AvailableImages =
    [
    new("Debian 12 (Bookworm Slim)", "debian:bookworm-slim"),
new("Ubuntu 22.04 LTS", "ubuntu:22.04"),
new("Ubuntu 24.04 LTS", "ubuntu:24.04"),
];

    // ── State ─────────────────────────────────────────────────────────────────

    private List<VirtualMachine> Vms { get; set; } = new();
    private double _cpuLimit = 55;
    private double _ramLimit = 4;
    private double CpuLimit => _cpuLimit;
    private double RamLimit => _ramLimit;
    private Provider? CurrentProvider { get; set; }
    private string CurrentNodeStatus { get; set; } = "Offline";
    private MachineSpecs? _specs;
    private CancellationTokenSource _saveCts = new();
    private bool _limitsLoaded = false;

    private bool _showLaunchModal = false;
    private bool _isLaunching = false;
    private string? _launchError = null;
    private string _selectedImage = "debian:bookworm-slim";
    private int _selectedCpuCores = 1;
    private int _selectedRamGB = 1;

    // Available resources = provider budget minus what running VMs already claim
    private int AvailableCpuCores =>
    Math.Max(0,
    (int)Math.Floor((CurrentProvider?.CpuLimitPercent ?? 0) / 100.0 * (_specs?.CpuCores ?? 0))
    - Vms.Where(v => v.Status == "Running").Sum(v => v.CpuCores));

    private int AvailableRamGB =>
    Math.Max(0,
    (int)Math.Floor(CurrentProvider?.RamLimitGB ?? 0)
    - Vms.Where(v => v.Status == "Running").Sum(v => v.RamGB));

    private bool _showStopModal = false;
    private bool _isStopping = false;
    private string? _stopError = null;
    private HashSet<string> _selectedVmIds = new();

    private FirestoreChangeListener? _vmListener;
    private FirestoreChangeListener? _providerListener;
    private FirestoreChangeListener? _requestListener;
    private readonly HashSet<string> _processedRequestIds = new();

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnChange += OnAuthStateChanged;
        await LoadProviderDataAsync();
        await StartListeners();
    }

    private async Task LoadProviderDataAsync()
    {
        if (AuthState.FirebaseUid == null) return;

        // Redirect to setup wizard if Docker is not reachable.
        if (!await DockerService.IsReachableAsync())
        {
            Nav.NavigateTo("/setup");
            return;
        }

        CurrentProvider = await ProviderService.GetByFirebaseUidAsync(AuthState.FirebaseUid);
        CurrentNodeStatus = CurrentProvider?.NodeStatus ?? "Offline";
        _cpuLimit = CurrentProvider?.CpuLimitPercent > 0 ? CurrentProvider.CpuLimitPercent : 55;
        _ramLimit = CurrentProvider?.RamLimitGB > 0 ? CurrentProvider.RamLimitGB : 1;
        _limitsLoaded = true;
        _specs = await MachineService.GetCachedSpecsAsync();

        if (_specs != null && _specs.RamGB > 0 && _ramLimit > _specs.RamGB)
        {
            _ramLimit = _specs.RamGB;
            await ProviderService.UpdateResourceLimitsAsync(_cpuLimit, _ramLimit, AuthState.FirebaseUid);
        }
    }

    private async Task StartListeners()
    {
        // Always set up VM listener (doesn't need auth)
        _vmListener = VmService.ListenAllVms(vms =>
        {
            var uid = AuthState.FirebaseUid;
            Vms = uid != null
    ? vms.Where(v => v.ProviderId == uid).ToList()
    : new List<VirtualMachine>();

            // Re-register any running VMs that aren't in the monitor's dictionary yet.
            // This happens when the user navigates away and back, because _monitored is
            // in-memory and only populated at launch time. TryAdd is a no-op for VMs
            // already being monitored, so this is safe to call on every Firestore update.
            foreach (var vm in Vms.Where(v => v.Status == "Running" && !string.IsNullOrEmpty(v.ContainerId)))
                MonitorService.StartMonitoring(vm.VmId, vm.ContainerId, vm.StartedAt ?? DateTime.UtcNow);

            _ = InvokeAsync(StateHasChanged);
        });

        // Only set up authenticated listeners if we have a Firebase UID
        if (string.IsNullOrWhiteSpace(AuthState.FirebaseUid))
        {
            // Clear any existing listeners if auth is not available
            if (_requestListener != null)
            {
                await _requestListener.StopAsync();
                _requestListener = null;
            }
            return;
        }

        var uid = AuthState.FirebaseUid;

        // Start/restart pause-resume listener
        PauseResumeListenerService.StartListening(uid);

        // Start/restart provider listener
        _providerListener = ProviderService.ListenByFirebaseUid(uid, provider =>
        {
            CurrentProvider = provider;
            CurrentNodeStatus = provider?.NodeStatus ?? "Offline";

            if (_limitsLoaded)
            {
                if (provider?.CpuLimitPercent > 0) _cpuLimit = provider.CpuLimitPercent;
                if (provider?.RamLimitGB > 0) _ramLimit = provider.RamLimitGB;
            }

            _ = InvokeAsync(StateHasChanged);
        });

        // Start/restart request listener with defensive error handling
        try
        {
            // Stop existing listener if it exists
            if (_requestListener != null)
            {
                await _requestListener.StopAsync();
            }

            _requestListener = FirestoreDb
            .Collection("vm_requests")
            .WhereEqualTo("provider_uid", uid)
            .WhereEqualTo("status", "pending")
            .Listen(OnRequestSnapshot);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ERROR] Failed to start request listener: {ex.Message}");
        }
    }

    private void OnAuthStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadProviderDataAsync();
            await StartListeners();
            StateHasChanged();
        });
    }

    // ── Launch modal ──────────────────────────────────────────────────────────

    private void OpenLaunchModal()
    {
        _launchError = null;
        _selectedCpuCores = AvailableCpuCores > 0 ? 1 : 0;
        _selectedRamGB = AvailableRamGB > 0 ? 1 : 0;
        _showLaunchModal = true;
    }

    private void CloseLaunchModal()
    {
        if (!_isLaunching)
            _showLaunchModal = false;
    }

    private async Task LaunchVmAsync()
    {
        _isLaunching = true;
        _launchError = null;
        StateHasChanged();

        try
        {
            // Guard: reject if the requested allocation exceeds remaining budget
            if (_selectedCpuCores < 1 || _selectedRamGB < 1 ||
            _selectedCpuCores > AvailableCpuCores || _selectedRamGB > AvailableRamGB)
            {
                _launchError = "Requested resources exceed your available UniCore budget.";
                return;
            }

            var vmId = Guid.NewGuid().ToString();
            var name = $"vm-{vmId[..8]}";
            var startedAt = DateTime.UtcNow;

            var relayPortStart = Configuration.GetValue<int>("FrpRelay:PortRangeStart", 2222);
            var relayPortEnd = Configuration.GetValue<int>("FrpRelay:PortRangeEnd", 2300);
            var usedPorts = Vms.Where(v => v.RelayPort.HasValue).Select(v => v.RelayPort!.Value).ToHashSet();
            var relayPort = Enumerable.Range(relayPortStart, relayPortEnd - relayPortStart + 1)
            .First(p => !usedPorts.Contains(p));

            var containerId = await DockerService.StartContainerAsync(
            name, _selectedImage, relayPort, _selectedCpuCores, _selectedRamGB);

            var sshPort = await DockerService.GetContainerSshPortAsync(containerId);

            var vm = new VirtualMachine
            {
                VmId = vmId,
                Name = name,
                ContainerId = containerId,
                StartedAt = startedAt,
                Status = "Running",
                Image = _selectedImage,
                ProviderId = AuthState.FirebaseUid ?? string.Empty,
                RelayPort = relayPort,
                SshPort = sshPort,
                CpuCores = _selectedCpuCores,
                RamGB = _selectedRamGB,
            };

            await VmService.CreateVmAsync(vm);
            MonitorService.StartMonitoring(vmId, containerId, startedAt);

            _showLaunchModal = false;
        }
        catch (Exception ex)
        {
            _launchError = ex.Message;
        }
        finally
        {
            _isLaunching = false;
            StateHasChanged();
        }
    }

    // ── Consumer VM request processing ────────────────────────────────────────

    private void OnRequestSnapshot(QuerySnapshot snapshot)
    {
        Console.WriteLine($"[DEBUG] OnRequestSnapshot fired with {snapshot.Documents.Count} documents");
        foreach (var doc in snapshot.Documents)
        {
            var req = doc.ConvertTo<VmRequest>();
            Console.WriteLine($"[DEBUG] Processing request {req.RequestId} with status '{req.Status}'");
            if (_processedRequestIds.Add(req.RequestId))
                _ = InvokeAsync(() => ProcessRequestAsync(req));
        }
    }

    private async Task ProcessRequestAsync(VmRequest request)
    {
        var docRef = FirestoreDb.Collection("vm_requests").Document(request.RequestId);

        try
        {
            Console.WriteLine($"[DEBUG] ProcessRequestAsync starting for request {request.RequestId}");
            await docRef.UpdateAsync(new Dictionary<string, object> { ["status"] = "processing" });

            if (request.CpuCores < 1 || request.RamGb < 1 ||
            request.CpuCores > AvailableCpuCores || request.RamGb > AvailableRamGB)
            {
                Console.WriteLine($"[DEBUG] Request {request.RequestId} failed: insufficient resources. Requested {request.CpuCores} CPU (available: {AvailableCpuCores}), {request.RamGb} RAM (available: {AvailableRamGB})");
                await docRef.UpdateAsync(new Dictionary<string, object>
                {
                    ["status"] = "failed",
                    ["error"] = "Provider does not have enough resources to fulfil this request.",
                });
                return;
            }

            var relayPortStart = Configuration.GetValue<int>("FrpRelay:PortRangeStart", 2222);
            var relayPortEnd = Configuration.GetValue<int>("FrpRelay:PortRangeEnd", 2300);
            var usedPorts = Vms.Where(v => v.RelayPort.HasValue).Select(v => v.RelayPort!.Value).ToHashSet();
            var relayPort = Enumerable.Range(relayPortStart, relayPortEnd - relayPortStart + 1)
            .First(p => !usedPorts.Contains(p));

            var vmId = Guid.NewGuid().ToString();
            var vmName = string.IsNullOrWhiteSpace(request.VmName) ? $"vm-{vmId[..8]}" : request.VmName;
            var startedAt = DateTime.UtcNow;

            Console.WriteLine($"[DEBUG] Starting Docker container {vmName} for request {request.RequestId}");
            var containerId = await DockerService.StartContainerAsync(
            vmName, request.Image, relayPort, request.CpuCores, request.RamGb);

            var sshPort = await DockerService.GetContainerSshPortAsync(containerId);

            var vm = new VirtualMachine
            {
                VmId = vmId,
                Name = vmName,
                ContainerId = containerId,
                StartedAt = startedAt,
                Status = "Running",
                Image = request.Image,
                ProviderId = AuthState.FirebaseUid ?? string.Empty,
                Client = request.ConsumerUid,
                RelayPort = relayPort,
                SshPort = sshPort,
                CpuCores = request.CpuCores,
                RamGB = request.RamGb,
            };

            await VmService.CreateVmAsync(vm);
            MonitorService.StartMonitoring(vmId, containerId, startedAt);

            Console.WriteLine($"[DEBUG] Request {request.RequestId} completed successfully with VM {vmId}");
            await docRef.UpdateAsync(new Dictionary<string, object>
            {
                ["status"] = "completed",
                ["vm_id"] = vmId,
            });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ERROR] ProcessRequestAsync failed for request {request.RequestId}: {ex.Message}\n{ex.StackTrace}");
            _processedRequestIds.Remove(request.RequestId);
            await docRef.UpdateAsync(new Dictionary<string, object>
            {
                ["status"] = "failed",
                ["error"] = ex.Message,
            });
        }
    }

    // ── Emergency stop modal ──────────────────────────────────────────────────

    private void OpenStopModal()
    {
        _stopError = null;
        _selectedVmIds = Vms.Where(v => v.Status == "Running").Select(v => v.VmId).ToHashSet();
        _showStopModal = true;
    }

    private void CloseStopModal()
    {
        if (!_isStopping)
            _showStopModal = false;
    }

    private void SelectAllVms() =>
    _selectedVmIds = Vms.Where(v => v.Status == "Running").Select(v => v.VmId).ToHashSet();

    private void DeselectAllVms() => _selectedVmIds = new();

    private void ToggleVmSelection(string vmId, bool isChecked)
    {
        if (isChecked) _selectedVmIds.Add(vmId);
        else _selectedVmIds.Remove(vmId);
    }

    private async Task StopSelectedVmsAsync()
    {
        _isStopping = true;
        _stopError = null;
        StateHasChanged();

        var errors = new List<string>();

        foreach (var vmId in _selectedVmIds.ToList())
        {
            var vm = Vms.FirstOrDefault(v => v.VmId == vmId);
            if (vm == null) continue;

            try
            {
                if (!string.IsNullOrEmpty(vm.ContainerId))
                    await DockerService.StopContainerAsync(vm.ContainerId, vm.Name);

                MonitorService.StopMonitoring(vmId);
                await VmService.DeleteVmAsync(vmId);
            }
            catch (Exception ex)
            {
                errors.Add($"{vm.Name}: {ex.Message}");
            }
        }

        _isStopping = false;

        if (errors.Any())
            _stopError = string.Join("; ", errors);
        else
            _showStopModal = false;

        StateHasChanged();
    }

    // ── Resource sliders ──────────────────────────────────────────────────────

    private readonly object _saveLock = new();

    private void OnSliderChanged(ref double field, double value)
    {
        field = value;
        _ = DebouncedSaveAsync().ContinueWith(t =>
        {
            if (t.IsFaulted)
                Console.WriteLine($"Save error: {t.Exception?.GetBaseException().Message}");
        }, TaskContinuationOptions.OnlyOnFaulted);
    }

    private async Task DebouncedSaveAsync()
    {
        CancellationTokenSource cts;
        lock (_saveLock)
        {
            _saveCts.Cancel();
            _saveCts.Dispose();
            _saveCts = new CancellationTokenSource();
            cts = _saveCts;
        }
        try
        {
            await Task.Delay(800, cts.Token);
            if (AuthState.FirebaseUid != null)
                await ProviderService.UpdateResourceLimitsAsync(_cpuLimit, _ramLimit, AuthState.FirebaseUid);
        }
        catch (OperationCanceledException) { }
    }

    // ── Node status ───────────────────────────────────────────────────────────

    private async Task HandleNodeStatusChanged(string newStatus)
    {
        try
        {
            if (AuthState.FirebaseUid != null)
            {
                await ProviderService.UpdateNodeStatusAsync(newStatus, AuthState.FirebaseUid);
                CurrentNodeStatus = newStatus;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to update node status: {ex.Message}");
        }
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        _ = _vmListener?.StopAsync();
        _ = _providerListener?.StopAsync();
        _ = _requestListener?.StopAsync();
        _ = PauseResumeListenerService.StopListening();
        lock (_saveLock)
        {
            _saveCts.Cancel();
            _saveCts.Dispose();
        }
    }
}