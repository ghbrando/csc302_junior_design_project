@page "/dashboard/"
@using unicoreprovider.Models
@using unicoreprovider.Services
@using unicoreprovider.Components
@using Microsoft.AspNetCore.Components.Web
@using System.Threading
@using Google.Cloud.Firestore
@implements IDisposable
@inject IVmService VmService
@inject IProviderService ProviderService
@inject IMachineService MachineService
@inject IDockerService DockerService
@inject ContainerMonitorService MonitorService
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inherits unicoreprovider.Services.AuthorizedPageBase

<PageTitle>Provider Node</PageTitle>

<style>
    .badge-online {
        background-color: rgba(0, 230, 118, 0.1);
        color: var(--uc-green);
        border: 1px solid rgba(0, 230, 118, 0.3);
        font-size: 0.65rem;
        padding: 0.35em 0.8em;
        letter-spacing: 1px;
    }

    .btn-emergency {
        border: 1px solid var(--uc-red-dark);
        color: var(--uc-red);
        font-size: 0.7rem;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.5rem 1rem;
        transition: all 0.2s;
    }

    .btn-emergency:hover {
        background-color: var(--uc-red-dark);
        color: white;
    }

    .btn-launch-vm {
        border: 1px solid rgba(0, 230, 118, 0.4);
        color: var(--uc-green);
        font-size: 0.7rem;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.5rem 1rem;
        transition: all 0.2s;
    }

    .btn-launch-vm:hover:not(:disabled) {
        background-color: rgba(0, 230, 118, 0.15);
        color: var(--uc-green);
    }

    .btn-launch-vm:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    /* CSS-driven modal — no JS interop needed */
    .uc-modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .uc-modal {
        background: var(--uc-dark-2);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 8px;
        padding: 1.75rem;
        width: 100%;
        max-width: 420px;
    }

    .uc-modal-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: #e2e8f0;
        margin-bottom: 1.25rem;
    }

    .uc-label {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.8px;
        color: #64748b;
        text-transform: uppercase;
        margin-bottom: 0.4rem;
    }

    .uc-select {
        background: #0f172a;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #e2e8f0;
        font-size: 0.83rem;
        border-radius: 4px;
        padding: 0.45rem 0.7rem;
        width: 100%;
    }

    .uc-select:focus {
        outline: none;
        border-color: rgba(0, 230, 118, 0.5);
    }
</style>

<div class="container-fluid px-4 py-3">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="d-flex align-items-center gap-3">
                <h5 class="fw-bold text-white mb-0" style="letter-spacing: 0.5px;">Provider Node</h5>
                <span class="badge rounded-pill badge-online">ONLINE</span>
            </div>
            <p class="text-muted mb-0 mt-1" style="font-size: 0.8rem;">Real-time resource monitoring & control</p>
        </div>

        <div class="d-flex align-items-center gap-2">
            <button class="btn btn-launch-vm rounded-1" @onclick="OpenLaunchModal">
                <i class="bi bi-play-circle me-2"></i> LAUNCH VM
            </button>
            <button class="btn btn-emergency rounded-1">
                <i class="bi bi-exclamation-octagon-fill me-2"></i> EMERGENCY STOP
            </button>
        </div>
    </div>

    <div class="row mb-3 g-3">
        @{
            var runningCount = Vms.Count(v => v.Status == "Running");
            var totalHourlyRate = Vms.Where(v => v.Status == "Running").Sum(v => v.CostPerHour);
            var longestUptime = Vms
                .Where(v => v.Status == "Running" && v.Uptime > TimeSpan.Zero)
                .OrderByDescending(v => v.Uptime)
                .Select(v => v.UptimeString)
                .FirstOrDefault();
            var uptime = longestUptime ?? "N/A";
        }

        <div class="col-12 col-md-6 col-lg-3">
            <NodeStatusCard NodeStatus="@CurrentNodeStatus" OnNodeStatusChanged="HandleNodeStatusChanged" />
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Active VMs" Value="@runningCount.ToString()" Unit="running"
                      IconClass="bi bi-activity" Color="#3b82f6" />
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Hourly Rate" Value="@totalHourlyRate.ToString("C")" Unit="/hr"
                      IconClass="bi bi-graph-up-arrow" Color="#00e676" ValueColor="#00e676" />
        </div>
        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Longest VM Uptime" Value="@uptime" Unit=""
                      IconClass="bi bi-lightning-charge-fill" Color="#ffeb3b" />
        </div>
    </div>

    <div class="row mb-3 g-3">
        <div class="col-md-6">
            <ResourceSlider Title="CPU CORE LIMIT" Unit="percent" Max="100" MinLimit="20" Color="#00E5FF"
                            IconClass="bi bi-cpu" Value="@CpuLimit"
                            ValueChanged="@(v => OnSliderChanged(ref _cpuLimit, v))" />
        </div>
        <div class="col-md-6">
            <ResourceSlider Title="RAM ALLOCATION" Unit="gigabytes"
                            Max="@(_specs?.RamGB > 0 ? (double)_specs.RamGB : 128)" MinLimit="1" Color="#D500F9"
                            IconClass="bi bi-hdd-rack" Value="@RamLimit"
                            ValueChanged="@(v => OnSliderChanged(ref _ramLimit, v))" />
        </div>
    </div>

    <div class="row mb-3 g-3">
        <div class="col-12">
            <h6 class="text-uppercase text-muted"
                style="font-size: 0.7rem; letter-spacing: 1px; margin-left: 4px; margin-bottom: 8px;">
                Real-Time Monitoring
            </h6>
        </div>
        @{
            var activeVms = Vms.Where(v => v.Status == "Running").ToList();
            var avgCpu = activeVms.Any() ? activeVms.Average(v => v.CurrentCpuUsage) : 0;
            var avgGpu = activeVms.Any() ? activeVms.Average(v => v.CurrentGpuUsage) : 0;
            var avgRam = activeVms.Any() ? activeVms.Average(v => v.CurrentRamUsage) : 0;
            var demoVm = activeVms.FirstOrDefault() ?? new VirtualMachine();
        }
        <div class="col-md-4">
            <MetricCard Title="CPU" Value="@avgCpu.ToString("0")" Percent="@((double)avgCpu)"
                        Color="#3b82f6" DataPoints="@demoVm.CpuHistory" />
        </div>
        <div class="col-md-4">
            <MetricCard Title="GPU" Value="@avgGpu.ToString("0")" Percent="@((double)avgGpu)"
                        Color="#10b981" DataPoints="@demoVm.GpuHistory" />
        </div>
        <div class="col-md-4">
            <MetricCard Title="RAM"
                        Value="@((activeVms.Sum(v => v.RamGB) * (avgRam / 100)).ToString("0.0"))" Unit="GB"
                        Percent="@((double)avgRam)" Color="#a855f7" DataPoints="@demoVm.RamHistory" />
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <VmList Vms="@Vms" />
        </div>
    </div>

</div>

<!-- Launch VM modal -->
@if (_showLaunchModal)
{
    <div class="uc-modal-backdrop" @onclick="CloseLaunchModal">
        <div class="uc-modal" @onclick:stopPropagation="true">
            <div class="uc-modal-title">
                <i class="bi bi-play-circle me-2" style="color: var(--uc-green);"></i>
                Launch Virtual Machine
            </div>

            <div class="mb-3">
                <div class="uc-label">Container Image</div>
                <select class="uc-select" @bind="_selectedImage">
                    @foreach (var img in AvailableImages)
                    {
                        <option value="@img.Value">@img.Label</option>
                    }
                </select>
            </div>

            @if (_launchError != null)
            {
                <div class="alert alert-danger py-2 mb-3" style="font-size: 0.78rem;">
                    <i class="bi bi-exclamation-circle me-1"></i>@_launchError
                </div>
            }

            <div class="d-flex justify-content-end gap-2 mt-3">
                <button class="btn btn-sm btn-outline-secondary rounded-1"
                        @onclick="CloseLaunchModal"
                        disabled="@_isLaunching">
                    Cancel
                </button>
                <button class="btn btn-sm btn-launch-vm rounded-1"
                        @onclick="LaunchVmAsync"
                        disabled="@_isLaunching">
                    @if (_isLaunching)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        <span>Launching...</span>
                    }
                    else
                    {
                        <i class="bi bi-play-circle me-1"></i>
                        <span>Launch</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── Available images ──────────────────────────────────────────────────────

    private record ImageOption(string Label, string Value);

    private static readonly ImageOption[] AvailableImages =
    [
        new("Debian 12 (Bookworm Slim)",  "debian:bookworm-slim"),
        new("Ubuntu 22.04 LTS",           "ubuntu:22.04"),
        new("Ubuntu 24.04 LTS",           "ubuntu:24.04"),
        new("Alpine 3.19 (Minimal)",      "alpine:3.19"),
    ];

    // ── State ─────────────────────────────────────────────────────────────────

    private List<VirtualMachine> Vms { get; set; } = new();
    private double _cpuLimit = 55;
    private double _ramLimit = 4;
    private double CpuLimit => _cpuLimit;
    private double RamLimit => _ramLimit;
    private Provider? CurrentProvider { get; set; }
    private string CurrentNodeStatus { get; set; } = "Offline";
    private MachineSpecs? _specs;
    private CancellationTokenSource _saveCts = new();
    private bool _limitsLoaded = false;

    private bool _showLaunchModal = false;
    private bool _isLaunching = false;
    private string? _launchError = null;
    private string _selectedImage = "debian:bookworm-slim";

    private FirestoreChangeListener? _vmListener;
    private FirestoreChangeListener? _providerListener;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnChange += OnAuthStateChanged;
        await LoadProviderDataAsync();
        StartListeners();
    }

    private async Task LoadProviderDataAsync()
    {
        if (AuthState.FirebaseUid == null) return;

        // Redirect to setup wizard if Docker is not reachable.
        if (!await DockerService.IsReachableAsync())
        {
            Nav.NavigateTo("/setup");
            return;
        }

        CurrentProvider = await ProviderService.GetByFirebaseUidAsync(AuthState.FirebaseUid);
        CurrentNodeStatus = CurrentProvider?.NodeStatus ?? "Offline";
        _cpuLimit = CurrentProvider?.CpuLimitPercent > 0 ? CurrentProvider.CpuLimitPercent : 55;
        _ramLimit = CurrentProvider?.RamLimitGB > 0 ? CurrentProvider.RamLimitGB : 1;
        _limitsLoaded = true;
        _specs = await MachineService.GetCachedSpecsAsync();

        if (_specs != null && _specs.RamGB > 0 && _ramLimit > _specs.RamGB)
        {
            _ramLimit = _specs.RamGB;
            await ProviderService.UpdateResourceLimitsAsync(_cpuLimit, _ramLimit, AuthState.FirebaseUid);
        }
    }

    private void StartListeners()
    {
        _vmListener = VmService.ListenAllVms(vms =>
        {
            var uid = AuthState.FirebaseUid;
            Vms = uid != null
                ? vms.Where(v => v.ProviderId == uid).ToList()
                : new List<VirtualMachine>();
            _ = InvokeAsync(StateHasChanged);
        });

        if (AuthState.FirebaseUid != null)
        {
            _providerListener = ProviderService.ListenByFirebaseUid(AuthState.FirebaseUid, provider =>
            {
                CurrentProvider = provider;
                CurrentNodeStatus = provider?.NodeStatus ?? "Offline";

                if (_limitsLoaded)
                {
                    if (provider?.CpuLimitPercent > 0) _cpuLimit = provider.CpuLimitPercent;
                    if (provider?.RamLimitGB > 0) _ramLimit = provider.RamLimitGB;
                }

                _ = InvokeAsync(StateHasChanged);
            });
        }
    }

    private void OnAuthStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadProviderDataAsync();
            StartListeners();
            StateHasChanged();
        });
    }

    // ── Launch modal ──────────────────────────────────────────────────────────

    private void OpenLaunchModal()
    {
        _launchError = null;
        _showLaunchModal = true;
    }

    private void CloseLaunchModal()
    {
        if (!_isLaunching)
            _showLaunchModal = false;
    }

    private async Task LaunchVmAsync()
    {
        _isLaunching = true;
        _launchError = null;
        StateHasChanged();

        try
        {
            var vmId = Guid.NewGuid().ToString();
            var name = $"vm-{vmId[..8]}";
            var startedAt = DateTime.UtcNow;

            var containerId = await DockerService.StartContainerAsync(name, _selectedImage);

            var vm = new VirtualMachine
            {
                VmId = vmId,
                Name = name,
                ContainerId = containerId,
                StartedAt = startedAt,
                Status = "Running",
                Image = _selectedImage,
                ProviderId = AuthState.FirebaseUid ?? string.Empty,
            };

            await VmService.CreateVmAsync(vm);
            MonitorService.StartMonitoring(vmId, containerId, startedAt);

            _showLaunchModal = false;
        }
        catch (Exception ex)
        {
            _launchError = ex.Message;
        }
        finally
        {
            _isLaunching = false;
            StateHasChanged();
        }
    }

    // ── Resource sliders ──────────────────────────────────────────────────────

    private readonly object _saveLock = new();

    private void OnSliderChanged(ref double field, double value)
    {
        field = value;
        _ = DebouncedSaveAsync().ContinueWith(t =>
        {
            if (t.IsFaulted)
                Console.WriteLine($"Save error: {t.Exception?.GetBaseException().Message}");
        }, TaskContinuationOptions.OnlyOnFaulted);
    }

    private async Task DebouncedSaveAsync()
    {
        CancellationTokenSource cts;
        lock (_saveLock)
        {
            _saveCts.Cancel();
            _saveCts.Dispose();
            _saveCts = new CancellationTokenSource();
            cts = _saveCts;
        }
        try
        {
            await Task.Delay(800, cts.Token);
            if (AuthState.FirebaseUid != null)
                await ProviderService.UpdateResourceLimitsAsync(_cpuLimit, _ramLimit, AuthState.FirebaseUid);
        }
        catch (OperationCanceledException) { }
    }

    // ── Node status ───────────────────────────────────────────────────────────

    private async Task HandleNodeStatusChanged(string newStatus)
    {
        try
        {
            if (AuthState.FirebaseUid != null)
            {
                await ProviderService.UpdateNodeStatusAsync(newStatus, AuthState.FirebaseUid);
                CurrentNodeStatus = newStatus;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to update node status: {ex.Message}");
        }
    }

    // ── Dispose ───────────────────────────────────────────────────────────────

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        _ = _vmListener?.StopAsync();
        _ = _providerListener?.StopAsync();
        lock (_saveLock)
        {
            _saveCts.Cancel();
            _saveCts.Dispose();
        }
    }
}
