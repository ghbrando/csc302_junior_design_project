@page "/dashboard/"
@using unicoreprovider.Models
@using unicoreprovider.Services
@using unicoreprovider.Components
@using Microsoft.AspNetCore.Components.Web
@using System.Threading
@implements IDisposable
@inject IVmService VmService
@inject IProviderService ProviderService
@inject IAuthStateService AuthState
@inject IMachineService MachineService
@rendermode RenderMode.InteractiveServer

<PageTitle>Provider Node</PageTitle>

<style>
    /* Custom "Online" Badge */
    .badge-online {
        background-color: rgba(0, 230, 118, 0.1);
        color: var(--uc-green);
        border: 1px solid rgba(0, 230, 118, 0.3);
        font-size: 0.65rem;
        padding: 0.35em 0.8em;
        letter-spacing: 1px;
    }

    /* Emergency Button */
    .btn-emergency {
        border: 1px solid var(--uc-red-dark);
        color: var(--uc-red);
        font-size: 0.7rem;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.5rem 1rem;
        transition: all 0.2s;
    }
    .btn-emergency:hover {
        background-color: var(--uc-red-dark);
        color: white;
    }
</style>

<div class="container-fluid px-4 py-3">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <div class="d-flex align-items-center gap-3">
                <h5 class="fw-bold text-white mb-0" style="letter-spacing: 0.5px;">Provider Node</h5>
                <span class="badge rounded-pill badge-online">ONLINE</span>
            </div>
            <p class="text-muted mb-0 mt-1" style="font-size: 0.8rem;">Real-time resource monitoring & control</p>
        </div>
        
        <button class="btn btn-emergency rounded-1">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> EMERGENCY STOP
        </button>
    </div>

    <div class="row mb-3 g-3">
        @{
            var runningCount = Vms.Count(v => v.Status == "Running");
            var totalHourlyRate = Vms.Where(v => v.Status == "Running").Sum(v => v.CostPerHour);
            var longestUptime = Vms
                .Where(v => v.Status == "Running" && v.Uptime > TimeSpan.Zero)
                .OrderByDescending(v => v.Uptime)
                .Select(v => v.UptimeString)
                .FirstOrDefault();
            var uptime = longestUptime ?? "N/A";
        }

        <div class="col-12 col-md-6 col-lg-3">
            <NodeStatusCard
                NodeStatus="@CurrentNodeStatus"
                OnNodeStatusChanged="HandleNodeStatusChanged" />
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Active VMs" 
                      Value="@runningCount.ToString()" 
                      Unit="running"
                      IconClass="bi bi-activity"
                      Color="#3b82f6" /> 
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Hourly Rate" 
                      Value="@totalHourlyRate.ToString("C")" 
                      Unit="/hr"
                      IconClass="bi bi-graph-up-arrow"
                      Color="#00e676"
                      ValueColor="#00e676" />
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <InfoCard Title="Longest VM Uptime"
                      Value="@uptime"
                      Unit=""
                      IconClass="bi bi-lightning-charge-fill"
                      Color="#ffeb3b" />
        </div>
    </div>

    <div class="row mb-3 g-3">
        <div class="col-md-6">
            <ResourceSlider Title="CPU CORE LIMIT"
                            Unit="percent"
                            Max="100" MinLimit="20"
                            Color="#00E5FF"
                            IconClass="bi bi-cpu"
                            Value="@CpuLimit"
                            ValueChanged="@(v => OnSliderChanged(ref _cpuLimit, v))" />
        </div>
        <div class="col-md-6">
            <ResourceSlider Title="RAM ALLOCATION"
                            Unit="gigabytes"
                            Max="@(_specs?.RamGB > 0 ? (double)_specs.RamGB : 128)" MinLimit="1"
                            Color="#D500F9"
                            IconClass="bi bi-hdd-rack"
                            Value="@RamLimit"
                            ValueChanged="@(v => OnSliderChanged(ref _ramLimit, v))" />
        </div>
    </div>

    <div class="row mb-3 g-3">
        <div class="col-12">
            <h6 class="text-uppercase text-muted" style="font-size: 0.7rem; letter-spacing: 1px; margin-left: 4px; margin-bottom: 8px;">Real-Time Monitoring</h6>
        </div>
        @{
            var activeVms = Vms.Where(v => v.Status == "Running").ToList();
            var avgCpu = activeVms.Any() ? activeVms.Average(v => v.CurrentCpuUsage) : 0;
            var avgGpu = activeVms.Any() ? activeVms.Average(v => v.CurrentGpuUsage) : 0;
            var avgRam = activeVms.Any() ? activeVms.Average(v => v.CurrentRamUsage) : 0;
            var demoVm = activeVms.FirstOrDefault() ?? new VirtualMachine();
        }

        <div class="col-md-4">
            <MetricCard Title="CPU" Value="@avgCpu.ToString("0")" Percent="@((double)avgCpu)" Color="#3b82f6" DataPoints="@demoVm.CpuHistory" /> 
        </div>
        <div class="col-md-4">
            <MetricCard Title="GPU" Value="@avgGpu.ToString("0")" Percent="@((double)avgGpu)" Color="#10b981" DataPoints="@demoVm.GpuHistory" />
        </div>
        <div class="col-md-4">
            <MetricCard Title="RAM" Value="@((activeVms.Sum(v => v.RamGB) * (avgRam/100)).ToString("0.0"))" Unit="GB" Percent="@((double)avgRam)" Color="#a855f7" DataPoints="@demoVm.RamHistory" />
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12">
             <VmList Vms="@Vms" />
        </div>
    </div>
</div>

@code {
    private List<VirtualMachine> Vms { get; set; } = new();
    private PeriodicTimer? _timer;
    private CancellationTokenSource _cts = new();
    private double _cpuLimit = 55;
    private double _ramLimit = 4;
    private double CpuLimit => _cpuLimit;
    private double RamLimit => _ramLimit;
    private Provider? CurrentProvider { get; set; }
    private string CurrentNodeStatus { get; set; } = "Offline";
    private MachineSpecs? _specs;
    private CancellationTokenSource _saveCts = new();
    private bool _limitsLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to auth state changes so hard-refresh restores data
        // when NavMenu sets auth from localStorage after first render
        AuthState.OnChange += OnAuthStateChanged;

        await LoadProviderDataAsync();

        await RefreshData();
        var token = _cts.Token;
        _ = StartTimerAsync(token).ContinueWith(t =>
        {
            if (t.IsFaulted)
                Console.WriteLine($"Timer error: {t.Exception?.GetBaseException().Message}");
        }, TaskContinuationOptions.OnlyOnFaulted);
    }

    private async Task LoadProviderDataAsync()
    {
        if (AuthState.FirebaseUid == null) return;

        CurrentProvider = await ProviderService.GetByFirebaseUidAsync(AuthState.FirebaseUid);
        CurrentNodeStatus = CurrentProvider?.NodeStatus ?? "Offline";
        _cpuLimit = CurrentProvider?.CpuLimitPercent > 0 ? CurrentProvider.CpuLimitPercent : 55;
        _ramLimit = CurrentProvider?.RamLimitGB > 0 ? CurrentProvider.RamLimitGB : 1;
        _limitsLoaded = true;
        _specs = await MachineService.GetCachedSpecsAsync();

        // Clamp _ramLimit to actual machine RAM so a stale saved value never exceeds the real max
        if (_specs != null && _specs.RamGB > 0 && _ramLimit > _specs.RamGB)
        {
            _ramLimit = _specs.RamGB;
            await ProviderService.UpdateResourceLimitsAsync(_cpuLimit, _ramLimit, AuthState.FirebaseUid);
        }
    }

    private void OnAuthStateChanged()
    {
        // Re-run data load on the render thread when auth is restored from localStorage
        _ = InvokeAsync(async () =>
        {
            await LoadProviderDataAsync();
            StateHasChanged();
        });
    }

    private readonly object _saveLock = new();

    private void OnSliderChanged(ref double field, double value)
    {
        field = value;
        _ = DebouncedSaveAsync().ContinueWith(t =>
        {
            if (t.IsFaulted)
                Console.WriteLine($"Save error: {t.Exception?.GetBaseException().Message}");
        }, TaskContinuationOptions.OnlyOnFaulted);
    }

    private async Task DebouncedSaveAsync()
    {
        CancellationTokenSource cts;
        lock (_saveLock)
        {
            _saveCts.Cancel();
            _saveCts.Dispose();
            _saveCts = new CancellationTokenSource();
            cts = _saveCts;
        }
        try
        {
            await Task.Delay(800, cts.Token);
            if (AuthState.FirebaseUid != null)
                await ProviderService.UpdateResourceLimitsAsync(_cpuLimit, _ramLimit, AuthState.FirebaseUid);
        }
        catch (OperationCanceledException) { }
    }

    private async Task StartTimerAsync(CancellationToken token)
    {
        _timer = new PeriodicTimer(TimeSpan.FromMilliseconds(500));
        try { while (await _timer.WaitForNextTickAsync(token)) { await RefreshData(); await InvokeAsync(StateHasChanged); } } catch (OperationCanceledException) { }
    }

    private async Task RefreshData()
    {
        Vms = (await VmService.GetAllVmsAsync()).ToList();

        if (AuthState.FirebaseUid != null)
        {
            CurrentProvider = await ProviderService.GetByFirebaseUidAsync(AuthState.FirebaseUid);
            CurrentNodeStatus = CurrentProvider?.NodeStatus ?? "Offline";
        }
    }

    private async Task HandleNodeStatusChanged(string newStatus)
    {
        try
        {
            if (AuthState.FirebaseUid != null)
            {
                await ProviderService.UpdateNodeStatusAsync(newStatus, AuthState.FirebaseUid);
                CurrentNodeStatus = newStatus;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to update node status: {ex.Message}");
        }
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        _cts.Cancel();
        _timer?.Dispose();
        _cts.Dispose();
        lock (_saveLock)
        {
            _saveCts.Cancel();
            _saveCts.Dispose();
        }
    }
}