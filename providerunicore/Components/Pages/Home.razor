@page "/"
@layout BlankLayout
@rendermode RenderMode.InteractiveServer

<div class="landing-logo">
    <img src="/provider_icon.png" alt="Unicore Logo" class="landing-logo-image" />
    <div class="landing-logo-title">UNICORE</div>
</div>

<div class="select-label mb-4">SELECT ACCOUNT TYPE</div>

<div class="account-cards">

    <!-- PROVIDER -->
    <div class="account-card">
        <div class="card-header-row">
            <div class="card-icon"
                 style="background:rgba(0,230,118,.08); border-color:rgba(0,230,118,.2); color:var(--uc-green);">
                <i class="bi bi-hdd-stack"></i>
            </div>
            <div>
                <div class="card-type">PROVIDER</div>
                <div class="card-sub">SHARE RESOURCES</div>
            </div>
        </div>

        <p class="card-desc">
            Earn revenue by sharing idle compute power from your hardware with the network.
        </p>

        <ul class="card-features">
            <li>Resource allocation control</li>
            <li>Flexible scheduling</li>
            <li>Automated payouts</li>
        </ul>

        <a href="/provider-login" class="card-continue" style="color:var(--uc-green);">
            CONTINUE <i class="bi bi-arrow-right"></i>
        </a>
    </div>
</div>

<div class="landing-footer mt-5">
    <span class="footer-badge"><i class="bi bi-shield-check"></i> SANDBOXED</span>
    <span class="footer-divider">|</span>
    <span class="footer-badge"><i class="bi bi-diagram-3"></i> DECENTRALIZED</span>
</div>

<style>
    .landing-logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 16px;
    }

    .landing-logo-image {
        width: 140px;
        height: 140px;
        object-fit: contain;
    }

    .landing-logo-title {
        font-size: 2rem;
        font-weight: 700;
        letter-spacing: 4px;
        color: var(--uc-text-white);
    }

    .logo-mark {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(0, 229, 255, 0.06);
        border: 1px solid rgba(0, 229, 255, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.75rem;
    }

    .logo-sub {
        font-size: 0.52rem;
        letter-spacing: 3.5px;
        color: var(--uc-text-dim);
        margin-top: 3px;
    }

    .select-label {
        margin-top: 30px;
        font-size: 0.7rem;
        letter-spacing: 4px;
        color: var(--uc-text-dim);
        text-align: center;
    }

    .account-cards {
        display: flex;
        gap: 1.25rem;
        width: 100%;
        max-width: 860px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .account-card {
        background-color: var(--uc-bg-card);
        border: 1px solid var(--uc-border);
        border-radius: var(--uc-radius);
        padding: 1.75rem;
        flex: 1;
        min-width: 280px;
        max-width: 400px;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: border-color 0.2s;
    }

    .account-card:hover {
        border-color: var(--uc-border-light);
    }

    .card-header-row {
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }

    .card-icon {
        width: 46px;
        height: 46px;
        border-radius: var(--uc-radius);
        border: 1px solid;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .card-type {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--uc-text-white);
        letter-spacing: 1px;
    }

    .card-sub {
        font-size: 0.58rem;
        letter-spacing: 2px;
        color: var(--uc-text-dim);
        margin-top: 2px;
    }

    .card-desc {
        font-size: 0.83rem;
        color: var(--uc-text-secondary);
        line-height: 1.65;
        margin: 0;
    }

    .card-features {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .card-features li {
        font-size: 0.68rem;
        letter-spacing: 1.5px;
        color: var(--uc-text-dim);
    }

    .card-features li::before {
        content: "•  ";
        color: var(--uc-text-dim);
    }

    .card-continue {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.68rem;
        letter-spacing: 2px;
        font-weight: 600;
        text-decoration: none;
        margin-top: auto;
        padding-top: 0.25rem;
        transition: gap 0.2s;
    }

    .card-continue:hover {
        gap: 11px;
        text-decoration: none;
    }

    .landing-footer {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .footer-divider {
        color: var(--uc-text-dim);
    }

    .footer-badge {
        font-size: 0.58rem;
        letter-spacing: 2px;
        color: var(--uc-text-secondary);
        display: flex;
        align-items: center;
        gap: 5px;
    }

    @@media (max-width: 768px) {
        .landing-logo-badge {
            width: 170px;
            height: 170px;
        }

        .landing-logo-image {
            width: 136px;
        }
    }
</style>