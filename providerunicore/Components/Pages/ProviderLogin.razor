@page "/provider-login"
@layout BlankLayout
@rendermode RenderMode.InteractiveServer
@inject NavigationManager Nav
@inject IFirebaseAuthService FirebaseAuth
@inject IProviderService ProviderService
@inject IAuthStateService AuthState
@inject IJSRuntime JS

<!-- Back link -->
<a href="/" class="back-link">
    <i class="bi bi-arrow-left"></i> BACK TO SELECTION
</a>

<!-- Login / Register Card -->
<div class="auth-card mt-4">

    <!-- Card header -->
    <div class="auth-card-header">
        <div class="auth-icon">
            <i class="bi bi-hdd-stack"></i>
        </div>
        <div>
            <div class="auth-title">@(isRegister ? "PROVIDER REGISTER" : "PROVIDER LOGIN")</div>
            <div class="auth-subtitle">Enter your credentials</div>
        </div>
    </div>

    <!-- Error banner -->
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="auth-error">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@errorMessage
        </div>
    }

    <!-- Form -->
    <div class="auth-form">

        @if (isRegister)
        {
            <div class="field-group">
                <label class="field-label">FULL NAME</label>
                <input class="field-input" type="text" placeholder="John Doe" @bind="name" @bind:event="oninput" @onkeydown="OnKeyDown" />
            </div>
        }

        <div class="field-group">
            <label class="field-label">EMAIL ADDRESS</label>
            <input class="field-input" type="email" placeholder="john@example.com" @bind="email"
                   @bind:event="oninput" @onkeydown="OnKeyDown" />
        </div>

        @if (!isReset)
        {
            <div class="field-group">
                <label class="field-label">PASSWORD</label>
                <div class="password-wrapper">
                    <input class="field-input" type="@(showPassword ? "text" : "password")" placeholder="••••••••" @bind="password" @bind:event="oninput" @onkeydown="OnKeyDown"/>
                    <button type="button" class="password-toggle" @onclick="TogglePassword" tabindex="-1">
                        <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                </div>
            </div>
        }

        <button class="auth-submit" @onclick="HandleSubmit" disabled="@isLoading">
            @if (isLoading)
            {
                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
            }
            @(isRegister ? "CREATE ACCOUNT" : isReset ? "SEND RESET LINK" : "CONTINUE AS PROVIDER")
        </button>

        <div class="auth-toggle">
            @if (isRegister)
            {
                <span>Already have an account?</span>
                <button class="toggle-btn" @onclick="() => { isRegister = false; errorMessage = string.Empty; }">
                    Sign In
                </button>
            }
            else if (isReset)
            {
                <span>Remember your password?</span>
                <button class="toggle-btn" @onclick="() => { isReset = false; errorMessage = string.Empty; }">
                    Back to Sign In
                </button>
            }
            else
            {
                <div style="display: flex; flex-direction: column; align-items: center;">
                    <div>
                        <span>Don't have an account?</span>
                        <button class="toggle-btn" @onclick="() => { isRegister = true; errorMessage = string.Empty; }">
                            Register
                        </button>
                    </div>
                    <button class="toggle-btn" @onclick="() => { isReset = true; errorMessage = string.Empty; }">
                        Forgot Password?
                    </button>
                </div>
            }
        </div>

    </div>
</div>

<TermsModal IsVisible="@showTermsModal" OnContinue="HandleTermsContinue" OnClose="HandleTermsClose" />

@code {
    private string name = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;

    private bool isRegister = false;
    private bool isReset = false;
    private bool isLoading = false;
    private bool showPassword = false;
    private bool showTermsModal = false;
    private string pendingProviderUid = string.Empty;
    private string errorMessage = string.Empty;

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        var validationError = ValidateInputs();
        if (validationError != null)
        {
            errorMessage = validationError;
            return;
        }

        isLoading = true;

        try
        {
            Provider? provider = null;

            if (isReset)
            {
                await FirebaseAuth.SendPasswordResetEmailAsync(email);
                errorMessage = "If the address exists, a reset link was sent.";
                return;
            }

            if (isRegister)
            {
                // Create Firebase user, then save provider in Firestore
                var idToken = await FirebaseAuth.SignUpAsync(email, password);
                var decoded = await FirebaseAuth.VerifyIDTokenAsync(idToken);
                var existing = await ProviderService.GetByFirebaseUidAsync(decoded.Uid);

                if (existing != null)
                {
                    errorMessage = "An account with this email already exists.";
                    return;
                }

                await FirebaseAuth.SendEmailVerificationAsync(idToken);

                provider = await ProviderService.CreateProviderAsync(name, email, decoded.Uid);
                AuthState.SetAuthState(decoded.Uid, email, name);
                await JS.InvokeVoidAsync("authStorage.save", decoded.Uid, email, name);

                errorMessage = "Account created! Please check your email to verify your account before logging in.";
                isRegister = false;
                return;
            }
            else
            {
                // Verify credentials and update last login
                var idToken = await FirebaseAuth.SignInAsync(email, password);
                var decoded = await FirebaseAuth.VerifyIDTokenAsync(idToken);

                if (!decoded.Claims.TryGetValue("email_verified", out var ev) || ev is not true)
                {
                    errorMessage = "Please verify your email before logging in. Check your inbox.";
                    return;
                }

                provider = await ProviderService.GetByFirebaseUidAsync(decoded.Uid);

                if (provider == null)
                {
                    errorMessage = "No provider account found. Please register first.";
                    return;
                }

                await ProviderService.UpdateLastLoginAsync(decoded.Uid);
                AuthState.SetAuthState(decoded.Uid, email, provider.Name);
                await JS.InvokeVoidAsync("authStorage.save", decoded.Uid, email, provider.Name);
            }

            if (provider == null)
            {
                errorMessage = "Provider account could not be loaded.";
                return;
            }

            if (!provider.TermsAccepted)
            {
                pendingProviderUid = provider.FirebaseUid;
                showTermsModal = true;
                return;
            }

            await CompleteLoginAndNavigateAsync(provider.FirebaseUid);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleTermsContinue()
    {
        if (string.IsNullOrWhiteSpace(pendingProviderUid))
        {
            showTermsModal = false;
            return;
        }

        await ProviderService.UpdateTermsAcceptedAsync(pendingProviderUid, true);
        showTermsModal = false;
        await CompleteLoginAndNavigateAsync(pendingProviderUid);
    }

    private Task HandleTermsClose()
    {
        showTermsModal = false;
        pendingProviderUid = string.Empty;
        return Task.CompletedTask;
    }

    private async Task CompleteLoginAndNavigateAsync(string firebaseUid)
    {
        await ProviderService.UpdateNodeStatusAsync("Online", firebaseUid);
        Nav.NavigateTo("/dashboard/");
    }

    private void TogglePassword() => showPassword = !showPassword;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleSubmit();
    }

    private string? ValidateInputs()
    {
        if (isRegister && string.IsNullOrWhiteSpace(name))
            return "Full name is required.";

        if (!System.Text.RegularExpressions.Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$"))
            return "Please enter a valid email address.";

        if (!isReset)
        {
            if (password.Length < 8)
                return "Password must be at least 8 characters.";

            if (!password.Any(char.IsDigit))
                return "Password must contain at least one number.";

            if (!password.Any(char.IsUpper))
                return "Password must contain at least one uppercase letter.";
        }

        return null;
    }
}

<style>
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 0.65rem;
        letter-spacing: 2px;
        color: var(--uc-text-dim);
        text-decoration: none;
        margin-bottom: 0.5rem;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--uc-text-secondary);
        text-decoration: none;
    }

    .auth-card {
        background-color: var(--uc-bg-card);
        border: 1px solid var(--uc-border);
        border-radius: var(--uc-radius);
        padding: 2rem;
        width: 100%;
        max-width: 420px;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .auth-card-header {
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }

    .auth-icon {
        width: 44px;
        height: 44px;
        border-radius: var(--uc-radius);
        background: rgba(0, 230, 118, 0.08);
        border: 1px solid rgba(0, 230, 118, 0.2);
        color: var(--uc-green);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        flex-shrink: 0;
    }

    .auth-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--uc-text-white);
        letter-spacing: 1px;
    }

    .auth-subtitle {
        font-size: 0.65rem;
        letter-spacing: 1.5px;
        color: var(--uc-text-dim);
        margin-top: 3px;
        font-family: var(--uc-font-mono);
    }

    .auth-error {
        background: rgba(255, 82, 82, 0.08);
        border: 1px solid rgba(255, 82, 82, 0.25);
        border-radius: var(--uc-radius);
        color: var(--uc-red);
        font-size: 0.78rem;
        padding: 0.6rem 0.85rem;
    }

    .auth-form {
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

    .field-label {
        font-size: 0.6rem;
        letter-spacing: 2px;
        color: var(--uc-text-dim);
        font-weight: 600;
    }

    .password-wrapper {
        display: flex;
        align-items: center;
        background-color: var(--uc-bg-elevated);
        border: 1px solid var(--uc-border);
        border-radius: var(--uc-radius);
        transition: border-color 0.2s;
    }

    .password-wrapper:focus-within {
        border-color: var(--uc-green);
    }

    .password-wrapper .field-input {
        flex: 1;
        background: none;
        border: none;
        outline: none;
        padding-right: 0;
    }

    .password-wrapper .field-input:focus {
        border-color: transparent;
    }

    .password-toggle {
        flex-shrink: 0;
        background: none;
        border: none;
        color: #888;
        cursor: pointer;
        padding: 0 0.7rem;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        line-height: 1;
    }

    .password-toggle:hover {
        color: #555;
    }

    .field-input {
        background-color: var(--uc-bg-elevated);
        border: 1px solid var(--uc-border);
        border-radius: var(--uc-radius);
        color: var(--uc-text-primary);
        font-size: 0.85rem;
        padding: 0.6rem 0.85rem;
        width: 100%;
        outline: none;
        transition: border-color 0.2s;
    }

    .field-input::placeholder {
        color: var(--uc-text-dim);
    }

    .field-input:focus {
        border-color: var(--uc-green);
    }

    .auth-submit {
        background-color: var(--uc-green);
        color: #000;
        border: none;
        border-radius: var(--uc-radius);
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 2px;
        padding: 0.75rem;
        width: 100%;
        cursor: pointer;
        transition: opacity 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-submit:hover:not(:disabled) {
        opacity: 0.88;
    }

    .auth-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .auth-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        font-size: 0.72rem;
        color: var(--uc-text-dim);
    }

    .toggle-btn {
        background: none;
        border: none;
        color: var(--uc-green);
        font-size: 0.72rem;
        font-weight: 600;
        cursor: pointer;
        padding: 0;
        text-decoration: underline;
    }

    /* Suppress browser-native password reveal button */
    input[type="password"]::-ms-reveal,
    input[type="password"]::-ms-clear {
        display: none;
    }
</style>