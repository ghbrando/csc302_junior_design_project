@page "/revenue/"
@using unicoreprovider.Services
@using unicoreprovider.Components
@using Google.Cloud.Firestore
@inherits unicoreprovider.Services.AuthorizedPageBase
@using Microsoft.AspNetCore.Components.Web
@using static unicoreprovider.Components.RevenueChart
@inject IProviderService ProviderService
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable


<PageTitle>Revenue Tracker</PageTitle>

<div class="container-fluid px-4 py-3">

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mb-3" role="alert">
            <strong>Error:</strong> @_errorMessage
        </div>
    }

    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold mb-0" style="letter-spacing: 0.5px; color: var(--uc-text-primary);">Revenue Tracker</h5>
            <p class="mb-0 mt-1" style="font-size: 0.8rem; color: var(--uc-text-secondary);">Monitor earnings and
                request payouts</p>
            </div>
            <button class="btn btn-payout rounded-1">
                <i class="bi bi-wallet2 me-2"></i> REQUEST PAYOUT
            </button>
        </div>

        @* Balance Cards *@
        <div class="row mb-3 g-3">
            <div class="col-12 col-md-4">
                <BalanceCard Title="Total Balance" Value="@FormatCurrency(583.50)" IconClass="bi bi-currency-dollar"
                             IconBgColor="rgba(0,230,118,0.15)" ValueColor="var(--uc-green)" />
            </div>
            <div class="col-12 col-md-4">
                <BalanceCard Title="Available" Value="@FormatCurrency(464.90)" IconClass="bi bi-graph-up-arrow"
                             IconBgColor="rgba(0,188,212,0.15)" ValueColor="var(--uc-cyan)" />
            </div>
            <div class="col-12 col-md-4">
                <BalanceCard Title="Pending" Value="@FormatCurrency(118.60)" IconClass="bi bi-clock-history"
                             IconBgColor="rgba(255,171,0,0.15)" ValueColor="var(--uc-amber)" />
            </div>
        </div>

        @* Revenue Chart *@
        <div class="row mb-3 g-3">
            <div class="col-12">
                <RevenueChart DataPoints="@RevenueData" CurrencySymbol="@CurrencySymbol" />
            </div>
        </div>

        @* Payout History *@
        <div class="row g-3">
            <div class="col-12">
                <PayoutHistory Payouts="@Payouts" CurrencySymbol="@CurrencySymbol" />
            </div>
        </div>
    </div>

    <style>
        .btn-payout {
            border: 1px solid var(--uc-green);
            color: var(--uc-green);
            font-size: 0.7rem;
            font-weight: bold;
            letter-spacing: 1px;
            padding: 0.5rem 1rem;
            transition: all 0.2s;
        }

        .btn-payout:hover {
            background-color: var(--uc-green);
            color: var(--uc-bg-body);
        }
    </style>

@code {
    String _currencyCode = "USD";
    private string CurrencySymbol => GetCurrencySymbol(_currencyCode);
    private string _errorMessage = "";
    private bool _providerLoaded;

    private Provider? CurrentProvider { get; set; }

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnChange += OnAuthStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
            await EnsureProviderLoadedAsync();
    }

    private void OnAuthStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await EnsureProviderLoadedAsync();
            StateHasChanged();
        });
    }

    private async Task EnsureProviderLoadedAsync()
    {
        if (_providerLoaded) return;
        if (string.IsNullOrWhiteSpace(AuthState.FirebaseUid)) return;

        try
        {
            CurrentProvider = await ProviderService.GetByFirebaseUidAsync(AuthState.FirebaseUid);
            _currencyCode = CurrentProvider?.Currency ?? "USD";
            _errorMessage = "";
            _providerLoaded = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading provider data: {ex.Message}";
            Console.WriteLine($"[ERROR] Revenue page: {ex}");
        }
    }
    private List<RevenueDataPoint> RevenueData { get; set; } = new()
    {
        new() { Date = new DateTime(2024, 1, 28), Amount = 45.00m },
        new() { Date = new DateTime(2024, 1, 29), Amount = 72.50m },
        new() { Date = new DateTime(2024, 1, 30), Amount = 58.00m },
        new() { Date = new DateTime(2024, 1, 31), Amount = 110.00m },
        new() { Date = new DateTime(2024, 2, 1), Amount = 95.00m },
        new() { Date = new DateTime(2024, 2, 2), Amount = 88.50m },
        new() { Date = new DateTime(2024, 2, 3), Amount = 114.50m },
    };

    private List<Payout> Payouts { get; set; } = new()
    {
        new() { Id = "PAY-2024-089", Date = new DateTime(2024, 2, 1), Amount = 245.00, Method = "Bank Transfer", Status =
"Completed" },
        new() { Id = "PAY-2024-088", Date = new DateTime(2024, 1, 28), Amount = 189.50, Method = "Bank Transfer", Status =
"Completed" },
        new() { Id = "PAY-2024-087", Date = new DateTime(2024, 1, 21), Amount = 312.00, Method = "Crypto", Status = "Completed" },
    };

    private string GetCurrencySymbol(string currencyCode)
    {
        return currencyCode switch
        {
            "EUR" => "€",
            "GBP" => "£",
            "JPY" => "¥",
            "CAD" => "C$",
            "AUD" => "A$",
            _ => "$"
        };
    }

    private string FormatCurrency(double amount)
    {
        return $"{CurrencySymbol}{amount:F2}";
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
    }
}