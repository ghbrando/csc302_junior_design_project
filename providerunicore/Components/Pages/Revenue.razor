@page "/revenue/"
@using unicoreprovider.Services
@using unicoreprovider.Components
@using Google.Cloud.Firestore
@inherits unicoreprovider.Services.AuthorizedPageBase
@using Microsoft.AspNetCore.Components.Web
@using static unicoreprovider.Components.RevenueChart
@inject IProviderService ProviderService
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@inject FirestoreDb firestoreDb
@inject IPaymentMethodService PaymentMethodService
@using unicore.shared.Models


<PageTitle>Revenue Tracker</PageTitle>

<div class="container-fluid px-4 py-3">

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger mb-3" role="alert">
            <strong>Error:</strong> @_errorMessage
        </div>
    }

    @* Header *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold mb-0" style="letter-spacing: 0.5px; color: var(--uc-text-primary);">Revenue Tracker</h5>
            <p class="mb-0 mt-1" style="font-size: 0.8rem; color: var(--uc-text-secondary);">Monitor earnings and
                request payouts</p>
            </div>
            <button class="btn btn-payout rounded-1" @onclick="OpenPayoutModalAsync"
                    disabled="@(_availableBalance <= 0)">
                <i class="bi bi-wallet2 me-2"></i> REQUEST PAYOUT
            </button>
        </div>

        @* Balance Cards *@
        <div class="row mb-3 g-3">
            <div class="col-12 col-md-4">
                @* Total accrued from current active sessions *@
                <BalanceCard Title="Lifetime Earnings" Value="@FormatCurrency(_totalEarnings)" />
            </div>
            <div class="col-12 col-md-4">
                @* Amount currently being processed *@
                <BalanceCard Title="Pending Payouts" Value="@FormatCurrency(_pendingPayouts)" IconBgColor="#e65100" />
            </div>
            <div class="col-12 col-md-4">
                @* Amount ready to be moved to bank *@
                <BalanceCard Title="Available Balance" Value="@FormatCurrency(_availableBalance)" IconBgColor="#0d47a1" />
            </div>
        </div>

        @* Revenue Chart *@
        <div class="row mb-3 g-3">
            <div class="col-12">
                <RevenueChart DataPoints="@RevenueData" CurrencySymbol="@CurrencySymbol" />
            </div>
        </div>

        @* Payout History *@
        <div class="row g-3">
            <div class="col-12">
                <PayoutHistory Payouts="@Payouts" CurrencySymbol="@CurrencySymbol" />
            </div>
        </div>

        @* Payout Modal *@
        @if (_showPayoutModal)
        {
            <div class="modal-backdrop" @onclick="() => _showPayoutModal = false">
                <div class="modal-box" @onclick:stopPropagation="true">
                    <h6 class="modal-title">REQUEST PAYOUT</h6>

                    <div class="modal-field">
                        <label class="modal-label">Amount</label>
                        <div class="modal-input-prefix">
                            <span>$</span>
                            <input type="number" 
                                value="@_payoutAmount.ToString("F2")"
                                @onchange="e => _payoutAmount = double.TryParse(e.Value?.ToString(), out var v) ? v : 0"
                                min="0.01" 
                                max="@((double)(Math.Floor((decimal)_availableBalance * 100) / 100))"
                                step="0.01"
                                style="background:transparent;border:none;color:var(--uc-text-white);font-size:0.95rem;width:100%;outline:none;" />
                        </div>
                        <p style="font-size:0.7rem;color:var(--uc-text-muted);margin-top:4px;">
                            Available: @FormatCurrency(_availableBalance)
                        </p>
                    </div>

                    <div class="modal-field">
                        <label class="modal-label">Payment Method</label>
                        @if (!_paymentMethods.Any())
                        {
                            <p style="font-size:0.8rem;color:#ff6b6b;">
                                No payment methods on file. Add one in Settings first.
                            </p>
                        }
                        else
                        {
                            <select @bind="_selectedMethodId" class="modal-select">
                                @foreach (var m in _paymentMethods)
                                {
                                    <option value="@m.Id">@m.DisplayLabel — @m.AccountHolderName @(m.IsPrimary ? "(Primary)" : "")</option>
                                }
                            </select>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(_payoutError))
                    {
                        <p style="font-size:0.75rem;color:#ff6b6b;margin-bottom:8px;">@_payoutError</p>
                    }

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button class="btn-modal-cancel" @onclick="() => _showPayoutModal = false">Cancel</button>
                        <button class="btn-modal-confirm" @onclick="ConfirmPayoutAsync"
                                disabled="@(!_paymentMethods.Any() || _payoutAmount <= 0)">
                            Confirm Payout
                        </button>
                    </div>
                </div>
            </div>
        }

        <style>
            .modal-backdrop {
                position: fixed; inset: 0; background: rgba(0,0,0,0.6);
                display: flex; align-items: center; justify-content: center; z-index: 2000;
            }
            .modal-box {
                background: var(--uc-bg-card); border: 1px solid var(--uc-border);
                border-radius: var(--uc-radius); padding: 1.5rem; width: 100%; max-width: 420px;
            }
            .modal-title {
                font-size: 0.75rem; font-weight: 700; letter-spacing: 1.2px;
                color: var(--uc-text-muted); margin-bottom: 1.25rem;
            }
            .modal-field { margin-bottom: 1rem; }
            .modal-label {
                font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em;
                color: var(--uc-text-muted); display: block; margin-bottom: 6px;
            }
            .modal-input-prefix {
                display: flex; align-items: center; gap: 6px;
                background: var(--uc-bg-body); border: 1px solid var(--uc-border);
                border-radius: var(--uc-radius); padding: 6px 10px;
                color: var(--uc-text-muted); font-size: 0.95rem;
            }
            .modal-select {
                width: 100%; background: var(--uc-bg-body); border: 1px solid var(--uc-border);
                border-radius: var(--uc-radius); color: var(--uc-text-white);
                font-size: 0.85rem; padding: 6px 10px;
            }
            .btn-modal-cancel {
                background: transparent; border: 1px solid var(--uc-border);
                color: var(--uc-text-muted); font-size: 0.75rem; padding: 6px 16px;
                border-radius: var(--uc-radius); cursor: pointer;
            }
            .btn-modal-confirm {
                background: var(--uc-green); color: #000; border: none;
                font-size: 0.75rem; font-weight: 700; padding: 6px 16px;
                border-radius: var(--uc-radius); cursor: pointer;
            }
            .btn-modal-confirm:disabled { opacity: 0.5; cursor: not-allowed; }
        </style>
    </div>

    <style>
        .btn-payout {
            border: 1px solid var(--uc-green-readable);
            color: var(--uc-green-readable);
            font-size: 0.7rem;
            font-weight: bold;
            letter-spacing: 1px;
            padding: 0.5rem 1rem;
            transition: all 0.2s;
        }

        .btn-payout:hover {
            background-color: var(--uc-green-readable);
            color: var(--uc-bg-body);
        }
    </style>

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private string _currencyCode = "USD";
    private string CurrencySymbol => GetCurrencySymbol(_currencyCode);
    private string _errorMessage = "";
    private bool _providerLoaded;
    private bool _listenersStarted;

    private double _totalEarnings;
    private double _availableBalance;
    private double _pendingPayouts;
    private List<VirtualMachine> _vms = new();
    private Provider? CurrentProvider { get; set; }
    private FirestoreChangeListener? _vmListener;
    private List<RevenueDataPoint> RevenueData { get; set; } = new();
    private List<Payout> Payouts { get; set; } = new();

    // ── Firestore Snapshot Logic ──────────────────────────────────────────────
    private void OnVmSnapshot(QuerySnapshot snapshot)
    {
        _vms = snapshot.Documents.Select(d => d.ConvertTo<VirtualMachine>()).ToList();
        RecalculateTotals();

        var cutoff = DateTime.UtcNow.Date.AddDays(-6);

        var grouped = _vms
            .Where(vm => vm.StartedAt != null && vm.StartedAt.Value.Date >= cutoff)
            .GroupBy(vm => vm.StartedAt.Value.Date)
            .Select(g => new RevenueDataPoint {
                Date = g.Key,
                Amount = (decimal)g.Sum(vm => CalculateProviderShare(vm))
            })
            .OrderBy(d => d.Date)
            .ToList();

        RevenueData = Enumerable.Range(0, 7)
            .Select(i => DateTime.UtcNow.Date.AddDays(-6 + i))
            .GroupJoin(
                grouped,
                date => date,
                point => point.Date,
                (date, points) => points.FirstOrDefault() ?? new RevenueDataPoint { Date = date, Amount = 0 }
            )
            .ToList();

        InvokeAsync(StateHasChanged);
    }

    private double CalculateProviderShare(VirtualMachine vm)
    {
        double volume = vm.VolumeRequestedGb ?? 0;
        double hourlyRate = (vm.CpuCores * 0.04) + (vm.RamGB * 0.006);
        double hoursUsed = vm.Uptime.TotalHours;
        double gross = (hourlyRate * hoursUsed) + (volume * 0.08) + (vm.ServicePort == 8080 ? 5.0 : 0.0);
        return gross * 0.70;
    }

    private void RecalculateTotals()
    {
        _pendingPayouts = Payouts.Where(p => p.Status == "Pending").Sum(p => p.Amount);
        _totalEarnings = Payouts.Where(p => p.Status == "Completed").Sum(p => p.Amount);

        if (_vms != null && _vms.Any())
        {
            double grossEarnings = _vms.Sum(vm => CalculateProviderShare(vm));
            _availableBalance = Math.Max(0, grossEarnings - _pendingPayouts);
        }
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
            await EnsureProviderLoadedAsync();
    }

    private void OnAuthStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            if (!_providerLoaded && !string.IsNullOrWhiteSpace(AuthState.FirebaseUid))
            {
                await EnsureProviderLoadedAsync();
                StateHasChanged();
            }
        });
    }

    private async Task EnsureProviderLoadedAsync()
    {
        if (_providerLoaded) return;
        if (string.IsNullOrWhiteSpace(AuthState.FirebaseUid)) return;

        try
        {
            CurrentProvider = await ProviderService.GetByFirebaseUidAsync(AuthState.FirebaseUid);
            _currencyCode = CurrentProvider?.Currency ?? "USD";

            if (!_listenersStarted)
            {
                StartListeners();
                _listenersStarted = true;
            }

            _errorMessage = "";
            _providerLoaded = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading provider data: {ex.Message}";
            StateHasChanged();
        }
    }

    private void StartListeners()
    {
        var vmQuery = firestoreDb.Collection("virtual_machines")
                                 .WhereEqualTo("providerId", AuthState.FirebaseUid);
        _vmListener = vmQuery.Listen(OnVmSnapshot);
        _ = FetchPayoutHistoryAsync();
    }

    private async Task FetchPayoutHistoryAsync()
    {
        try
        {
            var snapshot = await firestoreDb.Collection("payouts")
                                            .WhereEqualTo("provider_uid", AuthState.FirebaseUid)
                                            .OrderByDescending("timestamp")
                                            .GetSnapshotAsync();

            Payouts = snapshot.Documents.Select(d => new Payout {
                Id = d.Id,
                Date = d.ContainsField("timestamp") ? d.GetValue<DateTime>("timestamp") : DateTime.MinValue,
                Amount = d.ContainsField("amount") ? d.GetValue<double>("amount") : 0.0,
                Method = d.ContainsField("method") ? d.GetValue<string>("method") : "Unknown",
                Status = d.ContainsField("status") ? d.GetValue<string>("status") : "Pending"
            }).ToList();

            RecalculateTotals();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching payout history: {ex.Message}");
        }

        await InvokeAsync(StateHasChanged);
    }

    // State
    private bool _showPayoutModal;
    private double _payoutAmount;
    private string _selectedMethodId = "";
    private string _payoutError = "";
    private List<PaymentMethod> _paymentMethods = new();

    private async Task OpenPayoutModalAsync()
    {
        _payoutError = "";
        decimal available = Math.Floor((decimal)_availableBalance * 100) / 100;
        _paymentMethods = await PaymentMethodService.GetAllAsync(AuthState.FirebaseUid);
        var primary = _paymentMethods.FirstOrDefault(m => m.IsPrimary) ?? _paymentMethods.FirstOrDefault();
        _selectedMethodId = primary?.Id ?? "";
        _showPayoutModal = true;
    }

    private async Task ConfirmPayoutAsync()
    {
        _payoutError = "";

        decimal maxPayable = Math.Floor((decimal)_availableBalance * 100) / 100;
        decimal requested = Math.Round((decimal)_payoutAmount, 2);

        if (requested < 0.01m || requested > maxPayable)
        {
            _payoutError = $"Amount must be between $0.01 and ${maxPayable:F2}.";
            return;
        }
        if (string.IsNullOrEmpty(_selectedMethodId))
        {
            _payoutError = "Please select a payment method.";
            return;
        }

        try
        {
            var method = _paymentMethods.First(m => m.Id == _selectedMethodId);
            var payoutDoc = new Dictionary<string, object>
            {
                { "provider_uid",  AuthState.FirebaseUid },
                { "amount",        _payoutAmount },
                { "timestamp",     Timestamp.GetCurrentTimestamp() },
                { "status",        "Pending" },
                { "method",        method.DisplayLabel }
            };

            await firestoreDb.Collection("payouts").AddAsync(payoutDoc);
            _showPayoutModal = false;
            await FetchPayoutHistoryAsync();
        }
        catch (Exception ex)
        {
            _payoutError = $"Error: {ex.Message}";
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    private string GetCurrencySymbol(string currencyCode) => currencyCode switch
    {
        "EUR" => "€",
        "GBP" => "£",
        "JPY" => "¥",
        "CAD" => "C$",
        "AUD" => "A$",
        _ => "$"
    };

    private string FormatCurrency(double amount)
    {
        decimal floored = Math.Floor((decimal)amount * 100) / 100;
        return $"{CurrencySymbol}{floored:F2}";
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        _vmListener?.StopAsync();
        _vmListener = null;
        _listenersStarted = false;
        _providerLoaded = false;
    }
}