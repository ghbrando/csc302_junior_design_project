@page "/setup"
@using unicoreprovider.Services
@inherits unicoreprovider.Services.AuthorizedPageBase
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject IDockerService DockerService

<PageTitle>UniCore Setup</PageTitle>

<style>
    .setup-card { background: var(--uc-dark-2); border: 1px solid rgba(255,255,255,0.07); border-radius:8px; padding:2rem; max-width:640px; margin:0 auto; }
    .step-row { display:flex; gap:1rem; align-items:flex-start; }
    .step-title { font-size:0.9rem; font-weight:600; color:#e2e8f0 }
    .step-detail { font-size:0.78rem; color:#94a3b8; margin-top:0.25rem }
    .btn-setup { font-size:0.75rem; padding:0.45rem 1.1rem; border-radius:4px; margin-top:0.75rem }
</style>

<div class="container-fluid px-4 py-5">
    <div class="text-center mb-4">
        <h5 class="fw-bold text-white" style="letter-spacing:0.5px;">UniCore Node Setup</h5>
        <p class="text-muted" style="font-size:0.82rem;">This page verifies Docker connectivity. The app assumes Docker is already installed and configured.</p>
    </div>

    <div class="setup-card">
        <div class="step-row">
            <div class="flex-grow-1">
                <div class="step-title">Docker Connectivity</div>
                <div class="step-detail">
                    @if (_checking)
                    {
                        <span>Checking Docker connectivity...</span>
                    }
                    else if (string.IsNullOrEmpty(_errorMessage))
                    {
                        <span class="text-success">Docker is reachable — redirecting to dashboard.</span>
                    }
                    else
                    {
                        <span>@_errorMessage</span>
                        <br />
                        <button class="btn btn-setup btn-setup-primary" @onclick="CheckDockerAsync" disabled="@_checking">Retry</button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _checking = false;
    private string? _errorMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender && !string.IsNullOrEmpty(AuthState.FirebaseUid))
            await CheckDockerAsync();
    }

    private async Task CheckDockerAsync()
    {
        _checking = true;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            if (await DockerService.IsReachableAsync())
            {
                Nav.NavigateTo("/dashboard/");
                return;
            }

            _errorMessage = "Docker daemon is not reachable. Please ensure Docker is installed and running on this machine.";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _checking = false;
            StateHasChanged();
        }
    }
}
