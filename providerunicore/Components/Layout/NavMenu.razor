        transition: all 0.2s ease;
    }

    .sidebar-user:hover {
        background-color: rgba(255, 255, 255, 0.07);
        border-color: #444;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: var(--uc-radius);
        background-color: var(--uc-green);
        color: #000;
        font-weight: 700;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        text-transform: uppercase;
    }

    .user-details {
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .user-name {
        color: var(--uc-text-white);
        font-size: 0.78rem;
