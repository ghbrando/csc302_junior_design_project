@using Microsoft.AspNetCore.Components.Routing
@using providerunicore.Components.Dashboard
@using Google.Cloud.Firestore
@inject IAuthStateService AuthState
@inject IProviderService ProviderService
@inject NavigationManager Nav
@rendermode RenderMode.InteractiveServer
@inject IJSRuntime JS
@implements IDisposable

<nav class="sidebar d-flex flex-column">
    <!-- Removed default bottom margin from logo container -->
    <div class="sidebar-brand pb-0">
        <div class="sidebar-logo-badge">
            <img src="/unicore-logo.png" alt="Unicore Logo" class="sidebar-logo-image" />
        </div>
    </div>

    <!-- Removed default top margin and padding from the list -->
    <ul class="nav flex-column sidebar-nav pt-0">
        <li class="nav-item">
            <NavLink class="nav-link sidebar-link" href="dashboard" Match="NavLinkMatch.Prefix">
                <i class="bi bi-display"></i>
                <span>PROVIDER NODE</span>
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link sidebar-link" href="revenue" Match="NavLinkMatch.Prefix">
                <span class="currency-symbol">@CurrencySymbol</span>
                <span>REVENUE</span>
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link sidebar-link" href="settings" Match="NavLinkMatch.Prefix">
                <i class="bi bi-gear"></i>
                <span>SETTINGS</span>
            </NavLink>
        </li>
    </ul>

    <div class="sidebar-user">
        <div class="user-info">
            <div class="user-avatar">@(UserName.Length > 0 ? UserName[0] : '?')</div>
            <div class="user-details">
                <span class="user-name">@UserName</span>
                <span class="user-email">@UserEmail</span>
            </div>
        </div>
        <button class="logout-btn" @onclick="HandleLogout" @onclick:stopPropagation="true">
            <i class="bi bi-box-arrow-right"></i>
            <span>LOGOUT</span>
        </button>
    </div>
</nav>


@code {
    private string UserName => AuthState.Name ?? "Provider";
    private string UserEmail => AuthState.Email ?? "";
    private string CurrencySymbol { get; set; } = "$";
    private FirestoreChangeListener? _providerListener;

    protected override void OnInitialized()
    {
        AuthState.OnChange += OnAuthStateChanged;
    }

    private void OnAuthStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await StartProviderCurrencyListenerAsync();
            StateHasChanged();
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && string.IsNullOrEmpty(AuthState.FirebaseUid))
        {
            var authData = await JS.InvokeAsync<AuthData>("authStorage.load");
            if (!string.IsNullOrEmpty(authData?.uid))
            {
                AuthState.SetAuthState(authData.uid, authData.email ?? "", authData.name ?? "");
                StateHasChanged();
            }
        }

        if (firstRender)
            await StartProviderCurrencyListenerAsync();
    }

    private async Task StartProviderCurrencyListenerAsync()
    {
        if (string.IsNullOrWhiteSpace(AuthState.FirebaseUid)) return;

        if (_providerListener != null)
        {
            await _providerListener.StopAsync();
            _providerListener = null;
        }

        _providerListener = ProviderService.ListenByFirebaseUid(AuthState.FirebaseUid, provider =>
        {
            var currencyCode = provider?.Currency ?? "USD";
            CurrencySymbol = currencyCode switch
            {
                "EUR" => "€",
                "GBP" => "£",
                "JPY" => "¥",
                "CAD" => "C$",
                "AUD" => "A$",
                _ => "$"
            };
            _ = InvokeAsync(StateHasChanged);
        });
    }

    private async Task HandleLogout()
    {
        String firebaseUid = AuthState.FirebaseUid ?? "unknown-uid";
        await ProviderService.UpdateNodeStatusAsync("Offline", firebaseUid);
        AuthState.ClearAuthState();
        await JS.InvokeVoidAsync("authStorage.clear");
        Nav.NavigateTo("/", forceLoad: true);
    }

    // Lowercase property names to match the JS object from authStorage.load()
    private class AuthData
    {
        public string? uid { get; set; }
        public string? email { get; set; }
        public string? name { get; set; }
    }

    public void Dispose()
    {
        AuthState.OnChange -= OnAuthStateChanged;
        _ = _providerListener?.StopAsync();
    }
}

<style>
