@* UniCoreTermsModal.razor *@
@* Usage: <UniCoreTermsModal IsVisible="true" OnContinue="HandleContinue" OnClose="HandleClose" /> *@

@if(IsVisible)
{
    <div class="uc-screen">
        <div class="uc-modal">

            @* ── Header ───────────────────────────────────────── *@
            <div class="uc-header">
                <div class="uc-header-inner">
                    <div class="uc-header-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"
                             class="uc-icon-shield">
                            <path d="M12 3l7 3v6c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6l7-3z" />
                        </svg>
                    </div>
                    <div>
                        <h2 class="uc-title">Welcome to UniCore</h2>
                        <p class="uc-subtitle">Provider Account · Decentralized Cloud Infrastructure</p>
                    </div>
                </div>
                <button class="uc-close-btn" @onclick="HandleClose" aria-label="Close modal">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="uc-icon-sm">
                        <path d="M6 6l12 12M18 6L6 18" />
                    </svg>
                </button>
            </div>

            @* ── Scrollable Body ──────────────────────────────── *@
            <div class="uc-body">

                @* Terms of Service *@
                <section class="uc-tos-wrapper">
                    <div class="uc-tos-header">
                        <h3 class="uc-label-text">Terms of Service Agreement</h3>
                    </div>
                    <div class="uc-tos-body">
                        <div class="uc-tos-scroll">
                            <div class="uc-tos-clauses">
                                <p><span class="uc-tos-bold">1. Service Description:</span> UniCore provides a decentralized compute marketplace where users can offer or consume computational resources.</p>
                                <p><span class="uc-tos-bold">2. Provider Obligations:</span> Providers must maintain reasonable uptime, provide accurate hardware specifications, and allow VMs to run within scheduled periods.</p>
                                <p><span class="uc-tos-bold">3. Client Obligations:</span> Clients must submit legitimate workloads, respect provider resource limits, and pay for consumed resources promptly.</p>
                                <p><span class="uc-tos-bold">4. Security &amp; Privacy:</span> All VMs are sandboxed. UniCore does not access your personal data. Providers are responsible for their own system security.</p>
                                <p><span class="uc-tos-bold">5. Payment Terms:</span> Payments are processed through verified methods. Clients are charged based on actual resource usage. Providers receive payouts after verification.</p>
                                <p><span class="uc-tos-bold">6. Liability:</span> UniCore is not liable for hardware damage, data loss, or service interruptions. Use at your own risk.</p>
                            </div>
                        </div>
                        <label class="uc-agree-row">
                            <input type="checkbox" class="uc-checkbox" @bind="_hasAgreed" />
                            <span class="uc-agree-label">
                                I have read and agree to the Terms of Service, including the automated sandboxing and compute control authorization policies.
                            </span>
                        </label>
                    </div>
                </section>
                

            </div>@* /.uc-body *@

            @* ── Footer ───────────────────────────────────────── *@
            <div class="uc-footer">
                <button class="uc-btn @(_hasAgreed ? "uc-btn--active" : "uc-btn--locked")"
                        disabled="@(!_hasAgreed)"
                        @onclick="HandleContinue">
                    @(_hasAgreed ? "Continue →" : "Please Agree to the Terms to Continue")
                </button>
            </div>

        </div>
    </div>
}

@* ═══════════════════════════════════════════════════════════
   Code-behind — unchanged
   ═══════════════════════════════════════════════════════════ *@
@code {
    /// <summary>Controls modal visibility.</summary>
    [Parameter] public bool IsVisible { get; set; } = true;

    /// <summary>Raised when the user clicks Continue after agreeing.</summary>
    [Parameter] public EventCallback OnContinue { get; set; }

    /// <summary>Raised when the user closes the modal without agreeing.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _hasAgreed = false;

    private async Task HandleContinue()
    {
        if (_hasAgreed)
            await OnContinue.InvokeAsync();
    }

    private async Task HandleClose()
    {
        _hasAgreed = false;
        await OnClose.InvokeAsync();
    }
}

@* ═══════════════════════════════════════════════════════════
   Styles — move to app.css / unicore.css if preferred
   ═══════════════════════════════════════════════════════════ *@
<style>
    /* ── Reset ──────────────────────────────────────────── */
    .uc-screen *,
    .uc-screen *::before,
    .uc-screen *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Full-screen wrapper ────────────────────────────── */
    .uc-screen {
        position: fixed;
        inset: 0;
        z-index: 1000;
        min-height: 100dvh;
        background: rgba(0, 0, 0, 0.68);
        backdrop-filter: blur(2px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 12px;
        overflow: hidden;
        overscroll-behavior: contain;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
        color: #f4f4f5;
    }

    /* ── Modal shell ────────────────────────────────────── */
    .uc-modal {
        width: 100%;
        max-width: 52rem;
        height: min(56rem, calc(100dvh - 24px));
        border-radius: 0.875rem;
        border: 1px solid #27272a;
        background: #050608;
        box-shadow: 0 25px 60px rgba(0,0,0,.8);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    /* ── Header ─────────────────────────────────────────── */
    .uc-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        padding: 22px 26px;
        border-bottom: 1px solid #18181b;
        flex-shrink: 0;
    }
    .uc-header-inner { display: flex; align-items: flex-start; gap: 12px; }

    .uc-header-icon {
        display: flex; align-items: center; justify-content: center;
        width: 42px; height: 42px; flex-shrink: 0;
        border-radius: 10px;
        border: 1px solid rgba(52,211,153,.2);
        background: rgba(52,211,153,.1);
    }
    .uc-icon-shield { width: 20px; height: 20px; color: #6ee7b7; }

    .uc-title {
        font-size: 1.55rem; font-weight: 600;
        letter-spacing: -.025em; color: #fafafa; line-height: 1.2;
    }
    .uc-subtitle {
        margin-top: 3px; font-size: .6875rem;
        letter-spacing: .2em; text-transform: uppercase; color: #71717a;
    }



    .uc-close-btn {
        padding: 6px; border-radius: 7px;
        background: transparent; border: none;
        color: #71717a; cursor: pointer;
        transition: background .15s, color .15s;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .uc-close-btn:hover { background: #18181b; color: #e4e4e7; }
    .uc-icon-sm { width: 18px; height: 18px; }

    /* ── Scrollable body ────────────────────────────────── */
    .uc-body {
        overflow-y: auto;
        flex: 1;
        min-height: 0;
        padding: 18px 24px 22px;
        display: flex; flex-direction: column; gap: 20px;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
        scrollbar-color: #3f3f46 #09090b;
    }
    .uc-body::-webkit-scrollbar { width: 6px; }
    .uc-body::-webkit-scrollbar-track { background: #09090b; }
    .uc-body::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 3px; }

    /* ── Section labels ─────────────────────────────────── */
    .uc-section-label {
        display: flex; align-items: center; gap: 12px;
        margin-bottom: 12px;
    }
    .uc-label-text {
        font-size: .6875rem; font-weight: 600;
        letter-spacing: .18em; text-transform: uppercase; color: #e4e4e7;
    }
    .uc-icon-md { width: 18px; height: 18px; }
    .uc-icon-xs { width: 14px; height: 14px; }

    /* ── Color tokens ───────────────────────────────────── */
    .uc-emerald { color: #6ee7b7; }
    .uc-blue    { color: #93c5fd; }
    .uc-violet  { color: #c4b5fd; }
    .uc-amber   { color: #fcd34d; }

    /* ── Info cards ─────────────────────────────────────── */
    .uc-cards { display: flex; flex-direction: column; gap: 12px; }

    .uc-card {
        border-radius: 0.875rem; border: 1px solid; padding: 16px;
    }
    .uc-card--emerald { border-color: rgba(52,211,153,.2);  background: rgba(52,211,153,.05); }
    .uc-card--blue    { border-color: rgba(96,165,250,.2);  background: rgba(96,165,250,.05); }
    .uc-card--violet  { border-color: rgba(167,139,250,.2); background: rgba(167,139,250,.05); }

    .uc-card-title-row {
        display: flex; align-items: center; gap: 10px; margin-bottom: 6px;
    }
    .uc-card-check {
        display: inline-flex; align-items: center; justify-content: center;
        width: 18px; height: 18px; flex-shrink: 0;
        border-radius: 50%; border: 1px solid currentColor;
    }
    .uc-card-check--emerald { color: #6ee7b7; }
    .uc-card-check--blue    { color: #93c5fd; }
    .uc-card-check--violet  { color: #c4b5fd; }

    .uc-card-title { font-size: .95rem; font-weight: 500; line-height: 1.3; }
    .uc-card-desc  { padding-left: 28px; font-size: .875rem; line-height: 1.6; color: #a1a1aa; }

    /* ── Guidelines ─────────────────────────────────────── */
    .uc-guidelines {
        border-radius: 0.875rem;
        border: 1px solid rgba(245,158,11,.2);
        background: rgba(245,158,11,.05);
        padding: 16px 18px;
    }
    .uc-guidelines-list {
        list-style: none;
        display: flex; flex-direction: column; gap: 12px;
        font-size: .875rem; line-height: 1.6; color: #d4d4d8;
    }
    .uc-gl-bold { font-weight: 600; color: #fafafa; }

    /* ── Terms of Service ───────────────────────────────── */
    .uc-tos-wrapper {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        border-radius: 0.875rem;
        border: 1px solid #27272a;
        background: rgba(9,9,11,.7);
        overflow: hidden;
    }
    .uc-tos-header {
        border-bottom: 1px solid #27272a; padding: 12px 18px;
    }
    .uc-tos-body {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
        padding: 14px 18px;
    }

    .uc-tos-scroll {
        flex: 1;
        min-height: 0;
        max-height: none;
        overflow-y: auto;
        border-radius: 10px; border: 1px solid #27272a;
        background: rgba(0,0,0,.5);
        padding: 14px 12px 14px 14px;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
        scrollbar-color: #3f3f46 #09090b;
    }

    .uc-tos-scroll::-webkit-scrollbar { width: 6px; }
    .uc-tos-scroll::-webkit-scrollbar-track { background: #09090b; }
    .uc-tos-scroll::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 3px; }

    .uc-tos-clauses {
        display: flex; flex-direction: column; gap: 14px;
        font-size: .875rem; line-height: 1.6; color: #d4d4d8;
    }
    .uc-tos-bold { font-weight: 600; color: #fafafa; }

    /* ── Agree row ──────────────────────────────────────── */
    .uc-agree-row {
        display: flex; align-items: flex-start; gap: 12px;
        margin-top: 14px;
        font-size: .8125rem; color: #d4d4d8; cursor: pointer;
    }
    .uc-checkbox {
        margin-top: 2px; width: 15px; height: 15px; flex-shrink: 0;
        border-radius: 4px; border: 1px solid #52525b;
        background: transparent; accent-color: #34d399; cursor: pointer;
    }
    .uc-agree-label { line-height: 1.6; }

    /* ── Footer ─────────────────────────────────────────── */
    .uc-footer {
        border-top: 1px solid #18181b;
        padding: 18px 24px;
        flex-shrink: 0;
    }
    .uc-btn {
        display: block; width: 100%;
        border-radius: 10px; border: 1px solid;
        padding: 13px 16px;
        font-size: .8125rem; font-weight: 500;
        letter-spacing: .18em; text-transform: uppercase;
        cursor: pointer; font-family: inherit;
        transition: border-color .2s, color .2s, background .2s, box-shadow .2s;
    }
    .uc-btn--locked {
        background: #09090b; border-color: #27272a;
        color: #71717a; cursor: not-allowed;
    }
    .uc-btn--active {
        background: #052e16; border-color: rgba(52,211,153,.5);
        color: #6ee7b7; box-shadow: 0 0 20px rgba(52,211,153,.12);
    }
    .uc-btn--active:hover {
        border-color: #34d399; color: #a7f3d0;
        box-shadow: 0 0 28px rgba(52,211,153,.22);
    }

    @@media (max-width: 768px) {
        .uc-screen {
            padding: 8px;
        }

        .uc-modal {
            max-width: 100%;
            height: calc(100dvh - 16px);
        }

        .uc-body {
            padding: 16px 16px 20px;
        }

        .uc-tos-scroll {
            max-height: none;
        }
    }
</style>
